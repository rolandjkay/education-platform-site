---
import { useTranslations, localePath, languages, defaultLocale, type Locale } from '../i18n/utils';

interface Props {
  locale?: Locale;
  canonicalPath?: string;
}

const { locale = defaultLocale, canonicalPath = '/' } = Astro.props;
const t = useTranslations(locale);

const subjects = ['maths', 'science', 'finance', 'filmmaking'] as const;
const navLinks = subjects.map(s => ({
  label: t(`nav.${s}` as any),
  href: localePath(`/subjects/${s}`, locale),
}));

const homeHref = localePath('/', locale);
const currentPath = Astro.url.pathname;
---

<header class="navbar">
  <div class="navbar__inner container">
    <a href={homeHref} class="navbar__logo" aria-label="AFS Ed Online Learning — home">
      <span class="navbar__logo-mark" aria-hidden="true">AFS</span>
      <span class="navbar__logo-text">Online Learning</span>
    </a>

    <nav class="navbar__nav" aria-label="Main navigation">
      <ul class="navbar__links" role="list">
        {navLinks.map(({ label, href }) => (
          <li>
            <a
              href={href}
              class:list={['navbar__link', { 'navbar__link--active': currentPath.startsWith(href) }]}
              aria-current={currentPath.startsWith(href) ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="lang-switcher" aria-label={t('lang.label')}>
      {Object.entries(languages).map(([code, label]) => (
        <a
          href={localePath(canonicalPath, code as Locale)}
          class:list={['lang-switcher__link', { 'lang-switcher__link--active': code === locale }]}
          aria-current={code === locale ? 'true' : undefined}
          title={label}
        >{code === 'zh-CN' ? '简' : code === 'zh-TW' ? '繁' : code.toUpperCase().slice(0, 2)}</a>
      ))}
    </div>

    <button class="navbar__toggle" id="nav-toggle" aria-expanded="false" aria-controls="nav-menu" aria-label={t('nav.toggle')}>
      <span class="navbar__toggle-bar"></span>
      <span class="navbar__toggle-bar"></span>
      <span class="navbar__toggle-bar"></span>
    </button>
  </div>

  <!-- Mobile drawer -->
  <div class="navbar__drawer" id="nav-menu" hidden>
    <ul class="navbar__drawer-links" role="list">
      {navLinks.map(({ label, href }) => (
        <li>
          <a
            href={href}
            class:list={['navbar__drawer-link', { 'navbar__drawer-link--active': currentPath.startsWith(href) }]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <div class="navbar__drawer-lang" aria-label={t('lang.label')}>
      <span class="navbar__drawer-lang-label">{t('lang.label')}</span>
      <div class="navbar__drawer-lang-links">
        {Object.entries(languages).map(([code, label]) => (
          <a
            href={localePath(canonicalPath, code as Locale)}
            class:list={['navbar__drawer-lang-link', { 'navbar__drawer-lang-link--active': code === locale }]}
            aria-current={code === locale ? 'true' : undefined}
          >{label}</a>
        ))}
      </div>
    </div>
  </div>
</header>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-navy);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .navbar__inner {
    height: var(--nav-height);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  /* Logo */
  .navbar__logo {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
    color: inherit;
    flex-shrink: 0;
  }

  .navbar__logo-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: var(--color-primary);
    color: white;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    border-radius: var(--radius-sm);
    flex-shrink: 0;
  }

  .navbar__logo-text {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.9);
  }

  /* Desktop nav */
  .navbar__nav {
    flex: 1;
    display: flex;
    justify-content: flex-end;
  }

  .navbar__links {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin: 0;
    padding: 0;
  }

  .navbar__link {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    padding: 0.5rem 0.875rem;
    border-radius: var(--radius-full);
    transition: background var(--transition), color var(--transition);
  }

  .navbar__link:hover {
    background: rgba(255, 255, 255, 0.06);
    color: rgba(255, 255, 255, 0.95);
  }

  .navbar__link--active {
    color: var(--color-primary);
    background: rgba(234, 88, 12, 0.12);
  }

  /* Language switcher */
  .lang-switcher {
    display: flex;
    align-items: center;
    gap: 0.125rem;
    margin-left: 0.5rem;
  }

  .lang-switcher__link {
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.4);
    text-decoration: none;
    padding: 0.25rem 0.375rem;
    border-radius: var(--radius-sm);
    transition: color var(--transition), background var(--transition);
    line-height: 1;
  }

  .lang-switcher__link:hover {
    color: rgba(255, 255, 255, 0.85);
    background: rgba(255, 255, 255, 0.06);
  }

  .lang-switcher__link--active {
    color: var(--color-primary);
    background: rgba(234, 88, 12, 0.12);
  }

  @media (max-width: 640px) {
    .lang-switcher {
      display: none;
    }
  }

  /* Hamburger toggle */
  .navbar__toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    border-radius: var(--radius-sm);
    width: 40px;
    height: 40px;
  }

  .navbar__toggle:hover {
    background: var(--color-primary-faint);
  }

  .navbar__toggle-bar {
    display: block;
    width: 22px;
    height: 2px;
    background: rgba(255, 255, 255, 0.8);
    border-radius: 2px;
    transition: transform 200ms ease, opacity 200ms ease;
  }

  .navbar__toggle[aria-expanded="true"] .navbar__toggle-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .navbar__toggle[aria-expanded="true"] .navbar__toggle-bar:nth-child(2) {
    opacity: 0;
  }

  .navbar__toggle[aria-expanded="true"] .navbar__toggle-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Mobile drawer */
  .navbar__drawer {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    background: var(--color-navy);
    padding: 1rem 1.5rem 1.5rem;
  }

  .navbar__drawer-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .navbar__drawer-link {
    display: block;
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    padding: 0.75rem 1rem;
    border-radius: var(--radius);
    transition: background var(--transition), color var(--transition);
  }

  .navbar__drawer-link:hover,
  .navbar__drawer-link--active {
    background: rgba(255, 255, 255, 0.06);
    color: var(--color-primary);
  }

  .navbar__drawer-lang {
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .navbar__drawer-lang-label {
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
    display: block;
    margin-bottom: 0.625rem;
  }

  .navbar__drawer-lang-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .navbar__drawer-lang-link {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    padding: 0.375rem 0.75rem;
    border-radius: var(--radius-sm);
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: color var(--transition), background var(--transition), border-color var(--transition);
  }

  .navbar__drawer-lang-link:hover {
    color: rgba(255, 255, 255, 0.9);
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .navbar__drawer-lang-link--active {
    color: var(--color-primary);
    background: rgba(234, 88, 12, 0.12);
    border-color: rgba(234, 88, 12, 0.3);
  }

  @media (max-width: 640px) {
    .navbar__nav {
      display: none;
    }

    .navbar__toggle {
      display: flex;
    }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('nav-menu');

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    if (!expanded) {
      menu?.removeAttribute('hidden');
    } else {
      menu?.setAttribute('hidden', '');
    }
  });
</script>
