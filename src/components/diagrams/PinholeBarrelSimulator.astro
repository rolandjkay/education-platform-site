---
// Interactive pin-hole barrel simulator.
// Verbatim port of runPinHoleSimulatorApp() from:
//   Bootcamp-test/public/apps/pin-hole-simulator/public/script.js
// User drags a slider to adjust barrel length; rays and image update in real time.
---

<div class="pinhole-sim-wrap">
  <div class="pinhole-app-slider-container">
    <label for="pinhole-barrel-slider">Slide to adjust the lens barrel length:</label>
    <input id="pinhole-barrel-slider" class="pinhole-range" type="range" min="130" max="400" value="250" />
  </div>

  <svg id="pinhole-barrel-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 500 280" preserveAspectRatio="xMinYMin meet" aria-label="Interactive pin-hole camera simulator">
    <defs>
      <image id="ph-pumpkin" x="0" y="0" width="75" height="75" preserveAspectRatio="xMidYMid meet" href="data:image/png;base64,"/>


      <marker id="ph-arrow" markerWidth="10" markerHeight="10" refX="5" refY="3" orient="auto">
        <polygon points="4,3 9,4.5 9,1.5" fill="#ff927d"/>
      </marker>
      <marker id="ph-greyArrow" markerWidth="10" markerHeight="10" refX="5" refY="3" orient="auto">
        <polygon points="4,3 9,4.5 9,1.5" fill="#aaaaaa"/>
      </marker>
      <marker id="ph-blackArrow" markerWidth="10" markerHeight="10" refX="5" refY="3" orient="auto">
        <polygon points="4,3 9,4.5 9,1.5" fill="#555555"/>
      </marker>
      <marker id="ph-blackEndArrow" markerWidth="10" markerHeight="10" refX="5" refY="3" orient="auto">
        <polygon points="7,3 2,4.5 2,1.5" fill="#555555"/>
      </marker>
    </defs>

    <!-- White masks to clip the pumpkin viewfinder image -->
    <use id="ph-viewfinderImage" href="#ph-pumpkin" x="312.5" y="200" opacity=".7"/>
    <rect x="0" y="0" width="500" height="215" fill="white"/>
    <rect x="0" y="10" width="300" height="280" fill="white"/>
    <rect x="0" y="275" width="500" height="6" fill="white"/>
    <rect x="400" y="209" width="100" height="73" fill="white"/>

    <!-- Object pumpkin (scene) -->
    <use href="#ph-pumpkin" x="400" y="102.5"/>

    <!-- Fixed light rays from object corners -->
    <line x1="310" y1="40" x2="440" y2="102" stroke="#ff927d" stroke-width="2" stroke-linecap="round"/>
    <line x1="310" y1="40" x2="440" y2="177" stroke="#ff927d" stroke-width="2" stroke-linecap="round"/>
    <polygon points="0,4 9,8 9,0" fill="#ff927d" transform="rotate(205,380,76) translate(380,74)"/>
    <polygon points="0,4 9,8 9,0" fill="#ff927d" transform="rotate(224,380,92.5) translate(380,74)"/>

    <!-- Image (pumpkin, rotated 180°, dimmed — position updated by JS) -->
    <use id="ph-image" href="#ph-pumpkin" x="25" y="50" opacity="0.2" transform="rotate(180,62.5,87.5)"/>

    <!-- Pinhole (position updated by JS) -->
    <line id="ph-pinhole1" x1="250" y1="25" x2="250" y2="135" stroke="black" stroke-width="2"/>
    <line id="ph-pinhole2" x1="250" y1="255" x2="250" y2="145" stroke="black" stroke-width="2"/>
    <line id="ph-pinholeLabel" x1="260" y1="130" x2="280" y2="110" stroke="#aaaaaa" stroke-width="2" marker-start="url(#ph-greyArrow)"/>
    <text id="ph-pinholeLabelText" x="285" y="110" font-family="Arial" font-size="12" fill="#aaaaaa">Pin hole</text>

    <!-- Sensor -->
    <line id="ph-sensor" x1="100" y1="110" x2="100" y2="170" stroke="#555" stroke-width="2" stroke-dasharray="10,5" stroke-linecap="round"/>
    <text x="100" y="183" font-family="Arial" font-size="12" fill="black" text-anchor="middle">Camera Sensor</text>

    <!-- Moving light rays (endpoints updated by JS) -->
    <line id="ph-ray1" x1="50" y1="140" x2="440" y2="50" stroke="#ff927d" stroke-width="2" stroke-linecap="round" marker-start="url(#ph-arrow)"/>
    <line id="ph-ray2" x1="50" y1="140" x2="440" y2="125" stroke="#ff927d" stroke-width="2" stroke-linecap="round" marker-start="url(#ph-arrow)"/>

    <!-- Barrel length measurement -->
    <line id="ph-barrelLength" x1="100" y1="22" x2="200" y2="22" stroke="#555" stroke-width="2" stroke-linecap="round" marker-start="url(#ph-blackArrow)" marker-end="url(#ph-blackEndArrow)"/>
    <text id="ph-barrelLengthLabel2" x="150" y="14" font-family="Arial" font-size="12" fill="black" text-anchor="middle">"Lens" barrel length</text>
    <text id="ph-barrelLengthLabel"  x="150" y="34" font-family="Arial" font-size="12" fill="black" text-anchor="middle">150 mm</text>

    <!-- Sun -->
    <image href="/images/sun.svg" x="275" y="10" width="66" height="66"/>

    <!-- Viewfinder box -->
    <rect x="300" y="215" width="100" height="60" fill="none" stroke="black"/>
    <text x="350" y="210" font-family="Arial" font-size="12" fill="black" text-anchor="middle">Viewfinder</text>
  </svg>
</div>

<style>
  .pinhole-sim-wrap {
    margin: 2rem 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-bg-alt);
    overflow: hidden;
  }

  .pinhole-app-slider-container {
    padding: 1rem 1.25rem 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .pinhole-range {
    flex: 1;
    min-width: 160px;
    accent-color: var(--color-primary);
  }

  #pinhole-barrel-svg {
    display: block;
    width: 100%;
    height: auto;
  }
</style>

<script>
  const OBJECT_WIDTH = 75;
  const OBJECT_HEIGHT = 75;
  const imagePlaneX = 100;
  const objectPlaneX = 440;
  const pinHoleY = 140;
  const rayFixedYs = [pinHoleY - OBJECT_HEIGHT / 2, pinHoleY + OBJECT_HEIGHT / 2];

  const slider       = document.getElementById('pinhole-barrel-slider') as HTMLInputElement;
  const ray1         = document.getElementById('ph-ray1') as SVGLineElement;
  const ray2         = document.getElementById('ph-ray2') as SVGLineElement;
  const pinhole1     = document.getElementById('ph-pinhole1') as SVGLineElement;
  const pinhole2     = document.getElementById('ph-pinhole2') as SVGLineElement;
  const pinholeLabel = document.getElementById('ph-pinholeLabel') as SVGLineElement;
  const pinholeLabelText = document.getElementById('ph-pinholeLabelText') as SVGTextElement;
  const image        = document.getElementById('ph-image') as SVGUseElement;
  const viewfinderImage = document.getElementById('ph-viewfinderImage') as SVGUseElement;
  const barrelLength = document.getElementById('ph-barrelLength') as SVGLineElement;
  const barrelLabel  = document.getElementById('ph-barrelLengthLabel') as SVGTextElement;
  const barrelLabel2 = document.getElementById('ph-barrelLengthLabel2') as SVGTextElement;

  function calcRayImagePlaneY(fixedX: number, fixedY: number, pinHoleX: number) {
    const m = (pinHoleY - fixedY) / (pinHoleX - fixedX);
    return m * (imagePlaneX - pinHoleX) + pinHoleY;
  }

  function setImagePosition(x: number, y: number, scale: number, el: SVGUseElement) {
    el.setAttribute('x', String(x));
    el.setAttribute('y', String(y));
    const rotCx = x + OBJECT_WIDTH / 2, rotCy = y + OBJECT_HEIGHT / 2;
    const ax = x + OBJECT_WIDTH / 2, ay = y; // anchor at top (matches original)
    el.setAttribute('transform', `rotate(180,${rotCx},${rotCy}) translate(${ax},${ay}) scale(${scale},${scale}) translate(${-ax},${-ay})`);
  }

  function setViewfinderPosition(x: number, y: number, scale: number, el: SVGUseElement) {
    el.setAttribute('x', String(x));
    el.setAttribute('y', String(y));
    const ax = x + OBJECT_WIDTH / 2, ay = y + OBJECT_HEIGHT / 2;
    el.setAttribute('transform', `translate(${ax},${ay}) scale(${scale},${scale}) translate(${-ax},${-ay})`);
  }

  function update() {
    const pinHoleX = parseInt(slider.value);
    const imagePlaneYs = rayFixedYs.map(fy => calcRayImagePlaneY(objectPlaneX, fy, pinHoleX));

    pinhole1.setAttribute('x1', String(pinHoleX)); pinhole1.setAttribute('x2', String(pinHoleX));
    pinhole2.setAttribute('x1', String(pinHoleX)); pinhole2.setAttribute('x2', String(pinHoleX));
    pinhole2.setAttribute('y1', pinHoleX > 300 ? '200' : '255');
    pinholeLabel.setAttribute('x1', String(pinHoleX + 10)); pinholeLabel.setAttribute('x2', String(pinHoleX + 30));
    pinholeLabelText.setAttribute('x', String(pinHoleX + 35));

    ray1.setAttribute('y1', String(imagePlaneYs[0])); ray1.setAttribute('x1', String(imagePlaneX));
    ray2.setAttribute('y1', String(imagePlaneYs[1])); ray2.setAttribute('x1', String(imagePlaneX));

    const imageScale = (imagePlaneYs[0] - imagePlaneYs[1]) / OBJECT_HEIGHT;
    setImagePosition(imagePlaneX - OBJECT_HEIGHT / 2, imagePlaneYs[0] - OBJECT_HEIGHT, imageScale, image);
    setViewfinderPosition(312.5, 210, imageScale, viewfinderImage);

    barrelLength.setAttribute('x2', String(pinHoleX - 5));
    const midX = (pinHoleX + imagePlaneX) / 2;
    barrelLabel.setAttribute('x', String(midX));
    barrelLabel.textContent = `${pinHoleX - imagePlaneX} mm`;
    barrelLabel2.setAttribute('x', String(midX));
  }

  ray1.setAttribute('y2', String(rayFixedYs[0]));
  ray2.setAttribute('y2', String(rayFixedYs[1]));
  slider.addEventListener('input', update);
  update();
</script>
