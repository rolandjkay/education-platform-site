---
interface Props {
  locale?: string;
}
const { locale = 'en' } = Astro.props;
---

<figure class="diagram bac-diagram">
  <canvas id="bac-canvas" width="600" height="345"></canvas>
  <div class="bac-controls">
    <button id="bac-btn" class="bac-btn">Start simulation</button>
  </div>
  <figcaption>
    One bacterium splits every 0.5 seconds. Notice how the population stays small for a
    long time — then suddenly explodes. That's exponential growth: slow at first, then
    overwhelming.
  </figcaption>
</figure>

<style>
  .bac-diagram {
    margin: 2rem 0;
  }

  .bac-diagram canvas {
    display: block;
    width: 100%;
    aspect-ratio: 600 / 345;
    border-radius: var(--radius);
  }

  .bac-controls {
    padding: 0.5rem 0 0.25rem;
    text-align: center;
  }

  .bac-btn {
    padding: 0.35rem 1.1rem;
    border: 1px solid var(--color-primary, #2a7ae2);
    border-radius: 4px;
    background: transparent;
    color: var(--color-primary, #2a7ae2);
    font-family: var(--font-sans);
    font-size: 0.875rem;
    cursor: pointer;
  }

  .bac-btn:hover {
    background: var(--color-primary, #2a7ae2);
    color: #fff;
  }

  .bac-diagram figcaption {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-align: center;
    margin-top: 0.5rem;
  }
</style>

<script>
(function () {
  'use strict';

  const canvas = document.getElementById('bac-canvas');
  if (!(canvas instanceof HTMLCanvasElement)) return;
  const ctx = canvas.getContext('2d');
  const btn = document.getElementById('bac-btn');

  // ── DPR-aware sizing ─────────────────────────────────────────────────
  const dpr = Math.min(window.devicePixelRatio || 1, 2);
  const LW = 600, LH = 345;
  canvas.width  = Math.round(LW * dpr);
  canvas.height = Math.round(LH * dpr);
  ctx.scale(dpr, dpr);

  // ── Layout (logical pixels) ──────────────────────────────────────────
  const DCX = 143, DCY = 152, DR = 128; // petri dish centre & radius
  const GPX = 298, GPY = 28;            // graph plot area top-left
  const GPW = 282, GPH = 265;           // graph plot area width & height

  // ── Simulation constants ─────────────────────────────────────────────
  const SPLIT_S  = 0.5;   // seconds per generation
  const MAX_GEN  = 8;     // 8 doublings → 256 bacteria
  const SIM_END  = MAX_GEN * SPLIT_S; // 4.0 s
  const MAX_DISP = 64;    // max bacteria rendered in dish

  // ── Bacterium factory & helpers ──────────────────────────────────────
  function bacR(count) {
    return Math.max(4, Math.round(22 / Math.sqrt(Math.min(count, MAX_DISP))));
  }

  function makeBac(x, y, angle) {
    return {
      x, y,
      angle: (angle !== undefined) ? angle : Math.random() * Math.PI,
      hue: 115 + (Math.random() - 0.5) * 14,
    };
  }

  function clamp(b, r) {
    const d = Math.hypot(b.x - DCX, b.y - DCY);
    const limit = DR - r - 4;
    if (d > limit && d > 0) {
      const s = limit / d;
      b.x = DCX + (b.x - DCX) * s;
      b.y = DCY + (b.y - DCY) * s;
    }
  }

  function relax(bacs, r) {
    const minD = r * 2.4;
    for (let iter = 0; iter < 10; iter++) {
      for (let i = 0; i < bacs.length; i++) {
        for (let j = i + 1; j < bacs.length; j++) {
          const dx = bacs[j].x - bacs[i].x;
          const dy = bacs[j].y - bacs[i].y;
          const d  = Math.hypot(dx, dy);
          if (d < minD && d > 0.001) {
            const push = (minD - d) * 0.5;
            const nx = (dx / d) * push, ny = (dy / d) * push;
            bacs[i].x -= nx; bacs[i].y -= ny;
            bacs[j].x += nx; bacs[j].y += ny;
          }
        }
        clamp(bacs[i], r);
      }
    }
  }

  // ── Graph coordinate helpers (linear y-scale, 0–256) ────────────────
  const Y_MAX = 256;
  function gx(t) { return GPX + (t / SIM_END) * GPW; }
  function gy(n) { return GPY + GPH - (n / Y_MAX) * GPH; }

  // ── State ────────────────────────────────────────────────────────────
  let bacs, realCount, generation, phase, elapsed, running, lastTs, dataPoints, rafId;

  function reset() {
    bacs       = [makeBac(DCX, DCY)];
    realCount  = 1;
    generation = 0;
    phase      = 0;
    elapsed    = 0;
    running    = false;
    lastTs     = null;
    dataPoints = [{ t: 0, n: 1 }];
    rafId      = null;
  }

  function doSplit() {
    realCount *= 2;
    generation++;

    if (bacs.length >= MAX_DISP) {
      bacs.forEach(b => { b.angle = Math.random() * Math.PI; });
      dataPoints.push({ t: elapsed, n: realCount });
      return;
    }

    const newCount = Math.min(bacs.length * 2, MAX_DISP);
    const r = bacR(newCount);
    const next = [];
    for (const b of bacs) {
      if (next.length >= MAX_DISP) break;
      const offset = r * 1.5;
      const dx = Math.cos(b.angle) * offset;
      const dy = Math.sin(b.angle) * offset;
      const a = makeBac(b.x + dx, b.y + dy, b.angle + (Math.random() - 0.5) * 1.2);
      const c = makeBac(b.x - dx, b.y - dy, b.angle + (Math.random() - 0.5) * 1.2);
      clamp(a, r); clamp(c, r);
      next.push(a);
      if (next.length < MAX_DISP) next.push(c);
    }
    relax(next, r);
    bacs = next;
    dataPoints.push({ t: elapsed, n: realCount });
  }

  // ── Drawing ──────────────────────────────────────────────────────────

  function drawDish() {
    ctx.beginPath();
    ctx.arc(DCX, DCY, DR, 0, Math.PI * 2);
    ctx.fillStyle = '#eff8ee';
    ctx.fill();
    ctx.strokeStyle = '#8daa8d';
    ctx.lineWidth = 2.5;
    ctx.stroke();
    ctx.font = '12px system-ui, sans-serif';
    ctx.fillStyle = '#777';
    ctx.textAlign = 'center';
    ctx.fillText('Petri dish', DCX, DCY - DR - 6);
  }

  function drawBacteria() {
    const n = bacs.length;
    const r = bacR(n);
    const atCap = n >= MAX_DISP;

    let sx, sy, birthS;
    if (atCap) {
      const pulse = 1 + 0.07 * Math.sin(phase * Math.PI * 2);
      sx = pulse; sy = pulse; birthS = 1;
    } else {
      birthS = Math.min(1, phase / 0.10 + 0.25);
      const p = Math.max(0, (phase - 0.70) / 0.30);
      sx = 1 + p * 0.85;
      sy = 1 / sx;
    }

    for (const b of bacs) {
      ctx.save();
      ctx.translate(b.x, b.y);
      ctx.rotate(b.angle);
      ctx.scale(sx, sy);
      const dr = r * birthS;
      ctx.beginPath();
      ctx.arc(0, 0, dr, 0, Math.PI * 2);
      ctx.fillStyle = `hsl(${b.hue}, 50%, 36%)`;
      ctx.fill();
      ctx.strokeStyle = `hsl(${b.hue}, 38%, 26%)`;
      ctx.lineWidth = 0.8;
      ctx.stroke();
      ctx.beginPath();
      ctx.arc(-dr * 0.22, -dr * 0.28, dr * 0.30, 0, Math.PI * 2);
      ctx.fillStyle = `hsla(${b.hue + 15}, 55%, 72%, 0.40)`;
      ctx.fill();
      ctx.restore();
    }

    const label = realCount > MAX_DISP
      ? `${realCount.toLocaleString()} bacteria`
      : `${realCount} ${realCount === 1 ? 'bacterium' : 'bacteria'}`;
    ctx.textAlign = 'center';
    ctx.font = 'bold 13px system-ui, sans-serif';
    ctx.fillStyle = '#2e6e2e';
    ctx.fillText(label, DCX, DCY + DR + 20);
    ctx.font = '11px system-ui, sans-serif';
    ctx.fillStyle = '#888';
    ctx.fillText(`Generation ${generation}`, DCX, DCY + DR + 34);
  }

  function drawGraph() {
    // Background
    ctx.fillStyle = '#fafaf8';
    ctx.fillRect(GPX, GPY, GPW, GPH);

    // Grid
    ctx.strokeStyle = '#e6e6e6';
    ctx.lineWidth = 1;
    for (const n of [64, 128, 192, 256]) {
      const y = gy(n);
      ctx.beginPath(); ctx.moveTo(GPX, y); ctx.lineTo(GPX + GPW, y); ctx.stroke();
    }
    for (let t = 0; t <= SIM_END; t += 0.5) {
      const x = gx(t);
      ctx.beginPath(); ctx.moveTo(x, GPY); ctx.lineTo(x, GPY + GPH); ctx.stroke();
    }

    // Theoretical curve (always shown)
    ctx.save();
    ctx.strokeStyle = '#c0c0c0';
    ctx.lineWidth = 1.5;
    ctx.setLineDash([4, 3]);
    ctx.beginPath();
    for (let i = 0; i <= 120; i++) {
      const t = (i / 120) * SIM_END;
      const n = Math.pow(2, t / SPLIT_S);
      i === 0 ? ctx.moveTo(gx(t), gy(n)) : ctx.lineTo(gx(t), gy(n));
    }
    ctx.stroke();
    ctx.restore();

    // Actual data line
    if (dataPoints.length > 1) {
      ctx.strokeStyle = '#2e8a2e';
      ctx.lineWidth = 2;
      ctx.beginPath();
      dataPoints.forEach((p, i) => {
        i === 0 ? ctx.moveTo(gx(p.t), gy(p.n)) : ctx.lineTo(gx(p.t), gy(p.n));
      });
      ctx.stroke();
    }
    // Data points
    ctx.fillStyle = '#2e8a2e';
    for (const p of dataPoints) {
      ctx.beginPath();
      ctx.arc(gx(p.t), gy(p.n), 3.5, 0, Math.PI * 2);
      ctx.fill();
    }

    // Axes
    ctx.strokeStyle = '#444';
    ctx.lineWidth = 1.5;
    ctx.beginPath();
    ctx.moveTo(GPX, GPY); ctx.lineTo(GPX, GPY + GPH); ctx.lineTo(GPX + GPW, GPY + GPH);
    ctx.stroke();

    // Y ticks & labels
    ctx.fillStyle = '#555';
    ctx.font = '10px system-ui, sans-serif';
    ctx.strokeStyle = '#555';
    ctx.lineWidth = 1;
    ctx.textAlign = 'right';
    for (const n of [0, 64, 128, 192, 256]) {
      const y = gy(n);
      ctx.beginPath(); ctx.moveTo(GPX - 4, y); ctx.lineTo(GPX, y); ctx.stroke();
      ctx.fillText(String(n), GPX - 6, y + 3.5);
    }

    // X ticks & labels
    ctx.textAlign = 'center';
    for (let t = 0; t <= SIM_END; t++) {
      const x = gx(t);
      ctx.beginPath(); ctx.moveTo(x, GPY + GPH); ctx.lineTo(x, GPY + GPH + 4); ctx.stroke();
      ctx.fillText(t + 's', x, GPY + GPH + 13);
    }

    // Axis names
    ctx.font = 'italic 11px system-ui, sans-serif';
    ctx.fillStyle = '#666';
    ctx.textAlign = 'center';
    ctx.fillText('time', GPX + GPW / 2, GPY + GPH + 25);
    ctx.save();
    ctx.translate(GPX - 34, GPY + GPH / 2);
    ctx.rotate(-Math.PI / 2);
    ctx.fillText('bacteria', 0, 0);
    ctx.restore();

    // Panel title
    ctx.font = '12px system-ui, sans-serif';
    ctx.fillStyle = '#777';
    ctx.textAlign = 'center';
    ctx.fillText('Population over time', GPX + GPW / 2, GPY - 6);

    // Legend (top-left of graph area)
    ctx.save();
    ctx.strokeStyle = '#c0c0c0';
    ctx.lineWidth = 1.5;
    ctx.setLineDash([4, 3]);
    ctx.beginPath(); ctx.moveTo(GPX + 5, GPY + 12); ctx.lineTo(GPX + 24, GPY + 12); ctx.stroke();
    ctx.restore();
    ctx.font = '10px system-ui, sans-serif';
    ctx.fillStyle = '#888';
    ctx.textAlign = 'left';
    ctx.fillText('theoretical', GPX + 27, GPY + 15);

    ctx.save();
    ctx.strokeStyle = '#2e8a2e';
    ctx.lineWidth = 2;
    ctx.beginPath(); ctx.moveTo(GPX + 5, GPY + 27); ctx.lineTo(GPX + 24, GPY + 27); ctx.stroke();
    ctx.restore();
    ctx.fillStyle = '#888';
    ctx.fillText('actual', GPX + 27, GPY + 30);
  }

  function draw() {
    ctx.fillStyle = '#f6f6f4';
    ctx.fillRect(0, 0, LW, LH);
    drawDish();
    drawBacteria();
    drawGraph();
  }

  // ── Loop ─────────────────────────────────────────────────────────────
  function tick(ts) {
    if (!running) return;
    if (lastTs !== null) {
      const dt = Math.min((ts - lastTs) / 1000, 0.05);
      elapsed += dt;
      const newGen = Math.floor(elapsed / SPLIT_S);
      if (newGen > generation) doSplit();
      phase = (elapsed % SPLIT_S) / SPLIT_S;
    }
    lastTs = ts;
    draw();
    if (elapsed > SIM_END + SPLIT_S * 0.5) {
      running = false;
      btn.textContent = 'Restart';
      draw();
      return;
    }
    rafId = requestAnimationFrame(tick);
  }

  function start() {
    if (rafId) cancelAnimationFrame(rafId);
    reset();
    draw();
    running = true;
    lastTs = null;
    btn.textContent = 'Restart';
    rafId = requestAnimationFrame(tick);
  }

  btn.addEventListener('click', start);
  reset();
  draw();
})();
</script>
