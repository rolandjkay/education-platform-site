---
// Static SVG: A circle with radius r labelled.
import katex from 'katex';
const k = (tex: string) => katex.renderToString(tex, { throwOnError: false });

interface Props {
  locale?: string;
}
const { locale = 'en' } = Astro.props;

const labels: Record<string, Record<string, string>> = {
  en: { caption: 'A circle of radius r — what number do we multiply r² by to get the area?' },
  fr: { caption: 'Un cercle de rayon r — par quel nombre faut-il multiplier r² pour obtenir l\u2019aire ?' },
  de: { caption: 'Ein Kreis mit Radius r — mit welcher Zahl müssen wir r² multiplizieren, um die Fläche zu erhalten?' },
  es: { caption: 'Un círculo de radio r — ¿por qué número hay que multiplicar r² para obtener el área?' },
  it: { caption: 'Un cerchio di raggio r — per quale numero bisogna moltiplicare r² per ottenere l\u2019area?' },
  'zh-CN': { caption: '一个半径为 r 的圆——r² 乘以什么数才能得到面积？' },
  'zh-TW': { caption: '一個半徑為 r 的圓——r² 乘以什麼數才能得到面積？' },
  ja: { caption: '半径 r の円——面積を求めるには r² に何を掛ければよいでしょうか？' },
};

const t = { ...labels.en, ...(labels[locale] ?? {}) };
---

<figure class="diagram pi-circle">
  <svg xmlns="http://www.w3.org/2000/svg" width="100%" viewBox="0 0 400 320" aria-label="A circle with radius r labelled" role="img">

    <!-- The circle -->
    <circle cx="200" cy="150" r="120" fill="none" stroke="#555" stroke-width="2"/>

    <!-- Centre dot -->
    <circle cx="200" cy="150" r="3" fill="#555"/>

    <!-- Radius line from centre to right -->
    <line x1="200" y1="150" x2="320" y2="150" stroke="#6366f1" stroke-width="2"/>

    <!-- Radius label -->
    <foreignObject x="240" y="125" width="40" height="30">
      <span xmlns="http://www.w3.org/1999/xhtml" class="svg-katex" style="color:#6366f1" set:html={k('r')} />
    </foreignObject>

    <!-- Area label with question mark -->
    <foreignObject x="120" y="282" width="160" height="30">
      <span xmlns="http://www.w3.org/1999/xhtml" class="svg-katex" style="color:#333;display:block;text-align:center" set:html={k('\\text{Area} = {?} \\times r^2')} />
    </foreignObject>

  </svg>
  <figcaption>{t.caption}</figcaption>
</figure>

<style>
  .pi-circle {
    margin: 2rem 0;
  }

  .pi-circle svg {
    display: block;
    width: 100%;
    max-width: 420px;
    height: auto;
    margin: 0 auto;
    border-radius: var(--radius);
    background: var(--color-bg-alt);
    padding: 1rem;
  }

  .pi-circle figcaption {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-align: center;
    margin-top: 0.5rem;
  }

  .svg-katex {
    font-size: 14px;
    line-height: 1;
    white-space: nowrap;
  }

  .svg-katex :global(.katex) {
    font-size: 1em;
  }
</style>
