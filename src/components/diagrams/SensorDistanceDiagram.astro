---
// Static SVG: Moving the object closer to the aperture makes the image larger.
// Two side-by-side pin-hole scenarios showing object distance vs image size.
// Ported verbatim from Bootcamp-test/public/ed/gcse-physics.html
---

<figure class="diagram">
  <svg xmlns="http://www.w3.org/2000/svg" width="100%" viewBox="0 0 500 320" preserveAspectRatio="xMinYMin meet" aria-label="Diagram showing how moving the object closer to the aperture makes the image larger" role="img">
    <defs>
      <marker id="sdd-arrow" markerWidth="10" markerHeight="10" refX="5" refY="3" orient="auto">
        <polygon points="4,3 9,4.5 9,1.5" fill="#ff927d" />
      </marker>
      <marker id="sdd-endArrow" markerWidth="10" markerHeight="10" refX="5" refY="3" orient="auto">
        <polygon points="9,3 4,4.5 4,1.5" fill="#ff927d" />
      </marker>
      <marker id="sdd-greyArrow" markerWidth="10" markerHeight="10" refX="5" refY="3" orient="auto">
        <polygon points="4,3 9,4.5 9,1.5" fill="#aaaaaa" />
      </marker>

      <!-- Simple pumpkin stand-in: orange rectangle with eyes -->
      <g id="sdd-pumpkin">
        <rect x="0" y="0" width="30" height="35" rx="4" fill="#ff8c42" />
        <circle cx="9" cy="12" r="4" fill="#222" />
        <circle cx="21" cy="12" r="4" fill="#222" />
        <path d="M8 22 Q15 28 22 22" stroke="#222" stroke-width="1.5" fill="none" />
        <rect x="13" y="-5" width="4" height="7" rx="2" fill="#5a8a3c" />
      </g>
    </defs>

    <!-- ===== SCENARIO 1: Object far from pinhole → small image ===== -->
    <text x="125" y="14" font-family="Arial" font-size="11" fill="#555" text-anchor="middle">Object far → smaller image</text>

    <!-- Object (pumpkin) -->
    <use href="#sdd-pumpkin" transform="translate(210, 52)" />
    <!-- Image (pumpkin, rotated 180°, dimmed, scaled down) -->
    <use href="#sdd-pumpkin" transform="translate(55,70) rotate(180,15,17) scale(0.8)" opacity="0.3" />

    <!-- Pinhole -->
    <line x1="180" y1="40" x2="180" y2="82" stroke="black" stroke-width="2" />
    <line x1="180" y1="138" x2="180" y2="95" stroke="black" stroke-width="2" />
    <line x1="190" y1="78" x2="210" y2="58" stroke="#aaaaaa" stroke-width="1.5" marker-start="url(#sdd-greyArrow)" />
    <text x="215" y="58" font-family="Arial" font-size="11" fill="#aaaaaa">Pin hole</text>

    <!-- Sensor -->
    <line x1="70" y1="42" x2="70" y2="148" stroke="#555" stroke-width="2" stroke-dasharray="8,4" stroke-linecap="round" />
    <text x="70" y="162" font-family="Arial" font-size="11" fill="black" text-anchor="middle">Sensor</text>

    <!-- Light rays -->
    <line x1="70" y1="100" x2="225" y2="55" stroke="#ff927d" stroke-width="2" stroke-linecap="round" marker-start="url(#sdd-arrow)" />
    <line x1="70" y1="78"  x2="225" y2="118" stroke="#ff927d" stroke-width="2" stroke-linecap="round" marker-start="url(#sdd-arrow)" />

    <!-- ===== SCENARIO 2: Object close to pinhole → larger image ===== -->
    <text x="375" y="14" font-family="Arial" font-size="11" fill="#555" text-anchor="middle">Object closer → larger image</text>

    <!-- Object (pumpkin) -->
    <use href="#sdd-pumpkin" transform="translate(310, 170)" />
    <!-- Image (pumpkin, rotated 180°, dimmed, scaled up) -->
    <use href="#sdd-pumpkin" transform="translate(252,128) rotate(180,15,17) scale(1.5)" opacity="0.3" />

    <!-- Pinhole -->
    <line x1="310" y1="158" x2="310" y2="195" stroke="black" stroke-width="2" />
    <line x1="310" y1="252" x2="310" y2="215" stroke="black" stroke-width="2" />
    <line x1="320" y1="192" x2="340" y2="172" stroke="#aaaaaa" stroke-width="1.5" marker-start="url(#sdd-greyArrow)" />
    <text x="345" y="172" font-family="Arial" font-size="11" fill="#aaaaaa">Pin hole</text>

    <!-- Sensor -->
    <line x1="220" y1="160" x2="220" y2="260" stroke="#555" stroke-width="2" stroke-dasharray="8,4" stroke-linecap="round" />
    <text x="220" y="274" font-family="Arial" font-size="11" fill="black" text-anchor="middle">Sensor</text>

    <!-- Light rays -->
    <line x1="220" y1="255" x2="325" y2="172" stroke="#ff927d" stroke-width="2" stroke-linecap="round" marker-start="url(#sdd-arrow)" />
    <line x1="220" y1="160" x2="325" y2="235" stroke="#ff927d" stroke-width="2" stroke-linecap="round" marker-start="url(#sdd-arrow)" />
  </svg>
  <figcaption>Moving the object closer to the aperture makes the image larger, because the light ray enters at a steeper angle and travels further vertically across the sensor.</figcaption>
</figure>

<style>
  .diagram {
    margin: 2rem 0;
  }

  .diagram svg {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    background: var(--color-bg-alt);
    padding: 1rem;
  }

  .diagram figcaption {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-align: center;
    margin-top: 0.5rem;
  }
</style>
