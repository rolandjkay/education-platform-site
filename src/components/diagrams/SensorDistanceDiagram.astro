---
// Static SVG: Moving the object closer to the aperture makes the image larger.
// Two pin-hole scenarios showing object distance vs image size.
// Verbatim from Bootcamp-test/public/ed/gcse-physics.html lines 529-590.

interface Props {
  locale?: string;
}

const { locale = 'en' } = Astro.props;

const labels: Record<string, Record<string, string>> = {
  en: {
    labelPinHole: 'Pin hole',
    labelSensor:  'Camera Sensor',
    caption:      'Moving the object closer to the aperture also makes the image larger',
  },
  fr: {
    labelPinHole: 'Trou d\'épingle',
    labelSensor:  'Capteur photo',
    caption:      'Rapprocher l\'objet de l\'ouverture agrandit également l\'image',
  },
  de: {
    labelPinHole: 'Lochblende',
    labelSensor:  'Kamerasensor',
    caption:      'Das Objekt näher an die Apertur heranzubringen, vergrößert ebenfalls das Bild',
  },
  es: {
    labelPinHole: 'Orificio',
    labelSensor:  'Sensor de la cámara',
    caption:      'Acercar el objeto a la apertura también agranda la imagen',
  },
  it: {
    labelPinHole: 'Foro stenopeico',
    labelSensor:  'Sensore fotocamera',
    caption:      'Avvicinare l\'oggetto all\'apertura ingrandisce anch\'esso l\'immagine',
  },
  'zh-CN': {
    labelPinHole: '小孔',
    labelSensor:  '相机传感器',
    caption:      '将物体靠近光圈也会使图像变大',
  },
  'zh-TW': {
    labelPinHole: '小孔',
    labelSensor:  '相機感測器',
    caption:      '將物體靠近光圈也會使圖像變大',
  },
  ja: {
    labelPinHole: 'ピンホール',
    labelSensor:  'カメラセンサー',
    caption:      '物体を絞りに近づけると、像も大きくなります',
  },
};

const t = labels[locale] ?? labels.en;
---

<figure class="diagram">
  <svg xmlns="http://www.w3.org/2000/svg" width="100%" viewBox="0 0 500 320" preserveAspectRatio="xMinYMin meet" aria-label="Diagram showing how moving the object closer to the aperture makes the image larger" role="img">
    <defs>
      <image id="sdd-pumpkin" x="0" y="0" width="75" height="75" preserveAspectRatio="xMidYMid meet" href="/images/pumpkin.png"/>

      <marker id="sdd-arrow" markerWidth="10" markerHeight="10" refX="5" refY="3" orient="auto">
        <polygon points="4,3 9,4.5 9,1.5" fill="#ff927d" />
      </marker>
      <marker id="sdd-endArrow" markerWidth="10" markerHeight="10" refX="5" refY="3" orient="auto">
        <polygon points="9,3 4,4.5 4,1.5" fill="#ff927d" />
      </marker>
      <marker id="sdd-greyArrow" markerWidth="10" markerHeight="10" refX="5" refY="3" orient="auto">
        <polygon points="4,3 9,4.5 9,1.5" fill="#aaaaaa" />
      </marker>
    </defs>

    <!-- SCENARIO 1: Object far from pinhole → small image -->

    <!-- The object pumpkin -->
    <use href="#sdd-pumpkin" x="400" y="52.5" />
    <!-- Image (rotated, dimmed, scaled down) -->
    <use href="#sdd-pumpkin" x="-39" y="25" opacity="0.2" transform="scale(0.8) rotate(180, 62.5, 87.5)" />

    <!-- Pin hole -->
    <line x1="250" y1="40"  x2="250" y2="85"  stroke="black" stroke-width="2" />
    <line x1="250" y1="140" x2="250" y2="95"  stroke="black" stroke-width="2" />
    <line x1="260" y1="80"  x2="280" y2="60"  stroke="#aaaaaa" stroke-width="2" marker-start="url(#sdd-greyArrow)" />
    <text x="285" y="60" font-family="Arial" font-size="12" fill="#aaaaaa" text-anchor="start">{t.labelPinHole}</text>

    <!-- Sensor -->
    <line x1="100" y1="60" x2="100" y2="280" stroke="#555555" stroke-width="2" stroke-dasharray="10, 5" stroke-linecap="round" />
    <text x="100" y="300" font-family="Arial" font-size="12" fill="black" text-anchor="middle">{t.labelSensor}</text>

    <!-- Light rays -->
    <line x1="100" y1="120" x2="440" y2="53"  stroke="#ff927d" stroke-width="2" stroke-linecap="round" marker-start="url(#sdd-arrow)" />
    <line x1="100" y1="63"  x2="440" y2="125" stroke="#ff927d" stroke-width="2" stroke-linecap="round" marker-start="url(#sdd-arrow)" />

    <!-- SCENARIO 2: Object close to pinhole → larger image -->

    <!-- The object pumpkin -->
    <use href="#sdd-pumpkin" x="300" y="172.5" />
    <!-- Image (rotated, dimmed, scaled up) -->
    <use href="#sdd-pumpkin" x="25" y="8" opacity="0.2" transform="scale(1.65) rotate(180, 62.5, 87.5)" />

    <!-- Pin hole -->
    <line x1="250" y1="160" x2="250" y2="205" stroke="black" stroke-width="2" />
    <line x1="250" y1="260" x2="250" y2="215" stroke="black" stroke-width="2" />
    <line x1="260" y1="200" x2="280" y2="180" stroke="#aaaaaa" stroke-width="2" marker-start="url(#sdd-greyArrow)" />
    <text x="285" y="180" font-family="Arial" font-size="12" fill="#aaaaaa" text-anchor="start">{t.labelPinHole}</text>

    <!-- Light rays -->
    <line x1="100" y1="273" x2="340" y2="173" stroke="#ff927d" stroke-width="2" stroke-linecap="round" marker-start="url(#sdd-arrow)" />
    <line x1="100" y1="154" x2="340" y2="245" stroke="#ff927d" stroke-width="2" stroke-linecap="round" marker-start="url(#sdd-arrow)" />
  </svg>
  <figcaption>{t.caption}</figcaption>
</figure>

<style>
  .diagram {
    margin: 2rem 0;
  }

  .diagram svg {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    background: var(--color-bg-alt);
    padding: 1rem;
  }

  .diagram figcaption {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-align: center;
    margin-top: 0.5rem;
  }
</style>
