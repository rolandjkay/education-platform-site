---
// Static SVG: Convex (converging) vs concave (diverging) lens ray diagrams.
// Verbatim from Bootcamp-test/public/ed/gcse-physics.html lines 720-768.
---

<figure class="diagram">
  <svg xmlns="http://www.w3.org/2000/svg" width="100%" viewBox="0 50 800 350" aria-label="Side-by-side diagram of convex and concave lens ray paths" role="img">

    <!-- Convex lens (left) — converging rays -->
    <path d="M200,100 C190,200 190,200 200,300 L210,300 C220,200 220,200 210,100 Z" fill="blue" opacity="0.5"/>
    <text x="160" y="320" font-size="14" fill="black">Convex Lens</text>

    <line x1="100" y1="150" x2="200" y2="150" stroke="orange" stroke-width="2"/>
    <line x1="100" y1="175" x2="200" y2="175" stroke="orange" stroke-width="2"/>
    <line x1="100" y1="200" x2="200" y2="200" stroke="orange" stroke-width="2"/>
    <line x1="100" y1="225" x2="200" y2="225" stroke="orange" stroke-width="2"/>
    <line x1="100" y1="250" x2="200" y2="250" stroke="orange" stroke-width="2"/>

    <line x1="200" y1="150" x2="300" y2="200" stroke="orange" stroke-width="2"/>
    <line x1="200" y1="175" x2="300" y2="200" stroke="orange" stroke-width="2"/>
    <line x1="200" y1="200" x2="300" y2="200" stroke="orange" stroke-width="2"/>
    <line x1="200" y1="225" x2="300" y2="200" stroke="orange" stroke-width="2"/>
    <line x1="200" y1="250" x2="300" y2="200" stroke="orange" stroke-width="2"/>

    <!-- Concave lens (right) — diverging rays -->
    <path d="M560,100 C550,200 550,200 560,300 L530,300 C540,200 540,200 530,100 Z" fill="blue" opacity="0.5"/>
    <text x="500" y="320" font-size="14" fill="black">Concave Lens</text>

    <line x1="450" y1="150" x2="550" y2="150" stroke="orange" stroke-width="2"/>
    <line x1="450" y1="175" x2="550" y2="175" stroke="orange" stroke-width="2"/>
    <line x1="450" y1="200" x2="550" y2="200" stroke="orange" stroke-width="2"/>
    <line x1="450" y1="225" x2="550" y2="225" stroke="orange" stroke-width="2"/>
    <line x1="450" y1="250" x2="550" y2="250" stroke="orange" stroke-width="2"/>

    <line x1="550" y1="150" x2="650" y2="100" stroke="orange" stroke-width="2"/>
    <line x1="550" y1="175" x2="650" y2="150" stroke="orange" stroke-width="2"/>
    <line x1="550" y1="200" x2="650" y2="200" stroke="orange" stroke-width="2"/>
    <line x1="550" y1="225" x2="650" y2="250" stroke="orange" stroke-width="2"/>
    <line x1="550" y1="250" x2="650" y2="300" stroke="orange" stroke-width="2"/>
  </svg>
  <figcaption>A convex lens converges (focuses) light rays. A concave lens diverges (spreads) them.</figcaption>
</figure>

<style>
  .diagram {
    margin: 2rem 0;
  }

  .diagram svg {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    background: var(--color-bg-alt);
    padding: 1rem;
  }

  .diagram figcaption {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-align: center;
    margin-top: 0.5rem;
  }
</style>
