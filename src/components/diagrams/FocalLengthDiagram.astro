---
// Static SVG: Focal length — 50mm vs 100mm lens, showing where parallel rays converge.
// Verbatim from Bootcamp-test/public/ed/gcse-physics.html lines 805-850.
---

<figure class="diagram">
  <svg xmlns="http://www.w3.org/2000/svg" width="100%" viewBox="-25 0 775 400" aria-label="Diagram comparing 50mm and 100mm focal lengths" role="img">

    <!-- Lens 1 (focal length 50mm) -->
    <path d="M150,100 C165,200 165,200 150,300 L140,300 C125,200 125,200 140,100 Z" fill="blue" opacity="0.5"/>

    <line x1="0"   y1="150" x2="150" y2="150" stroke="orange" stroke-width="2"/>
    <line x1="0"   y1="175" x2="150" y2="175" stroke="orange" stroke-width="2"/>
    <line x1="0"   y1="200" x2="150" y2="200" stroke="orange" stroke-width="2"/>
    <line x1="0"   y1="225" x2="150" y2="225" stroke="orange" stroke-width="2"/>
    <line x1="0"   y1="250" x2="150" y2="250" stroke="orange" stroke-width="2"/>

    <line x1="150" y1="150" x2="250" y2="200" stroke="orange" stroke-width="2"/>
    <line x1="150" y1="175" x2="250" y2="200" stroke="orange" stroke-width="2"/>
    <line x1="150" y1="200" x2="250" y2="200" stroke="orange" stroke-width="2"/>
    <line x1="150" y1="225" x2="250" y2="200" stroke="orange" stroke-width="2"/>
    <line x1="150" y1="250" x2="250" y2="200" stroke="orange" stroke-width="2"/>

    <circle cx="250" cy="200" r="4" fill="red"/>
    <text x="255" y="190" font-size="14" fill="black">F</text>
    <text x="175" y="190" font-size="14" fill="black">50mm</text>

    <!-- Lens 2 (focal length 100mm) -->
    <path d="M450,100 C460,200 460,200 450,300 L440,300 C430,200 430,200 440,100 Z" fill="blue" opacity="0.5"/>

    <line x1="350" y1="150" x2="450" y2="150" stroke="orange" stroke-width="2"/>
    <line x1="350" y1="175" x2="450" y2="175" stroke="orange" stroke-width="2"/>
    <line x1="350" y1="200" x2="450" y2="200" stroke="orange" stroke-width="2"/>
    <line x1="350" y1="225" x2="450" y2="225" stroke="orange" stroke-width="2"/>
    <line x1="350" y1="250" x2="450" y2="250" stroke="orange" stroke-width="2"/>

    <line x1="450" y1="150" x2="650" y2="200" stroke="orange" stroke-width="2"/>
    <line x1="450" y1="175" x2="650" y2="200" stroke="orange" stroke-width="2"/>
    <line x1="450" y1="200" x2="650" y2="200" stroke="orange" stroke-width="2"/>
    <line x1="450" y1="225" x2="650" y2="200" stroke="orange" stroke-width="2"/>
    <line x1="450" y1="250" x2="650" y2="200" stroke="orange" stroke-width="2"/>

    <circle cx="650" cy="200" r="4" fill="red"/>
    <text x="650" y="190" font-size="14" fill="black">F</text>
    <text x="515" y="190" font-size="14" fill="black">100mm</text>
  </svg>
  <figcaption>Focal length is the distance from the lens to the point where parallel rays converge.</figcaption>
</figure>

