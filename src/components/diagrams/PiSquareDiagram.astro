---
// Static SVG: A square with side length 2r, showing the distance r from centre to edge.
import katex from 'katex';
const k = (tex: string) => katex.renderToString(tex, { throwOnError: false });

interface Props {
  locale?: string;
}
const { locale = 'en' } = Astro.props;

const labels: Record<string, Record<string, string>> = {
  en: { caption: 'A square with side length 2r — the distance from the centre to any edge is r' },
  fr: { caption: 'Un carré de côté 2r — la distance du centre à chaque bord est r' },
  de: { caption: 'Ein Quadrat mit Seitenlänge 2r — der Abstand von der Mitte zu jeder Kante beträgt r' },
  es: { caption: 'Un cuadrado de lado 2r — la distancia del centro a cualquier borde es r' },
  it: { caption: 'Un quadrato di lato 2r — la distanza dal centro a qualsiasi bordo è r' },
  'zh-CN': { caption: '一个边长为 2r 的正方形——从中心到任意一边的距离为 r' },
  'zh-TW': { caption: '一個邊長為 2r 的正方形——從中心到任意一邊的距離為 r' },
  ja: { caption: '一辺の長さが 2r の正方形——中心からどの辺までの距離も r' },
};

const t = { ...labels.en, ...(labels[locale] ?? {}) };
---

<figure class="diagram pi-square">
  <svg xmlns="http://www.w3.org/2000/svg" width="100%" viewBox="0 0 400 340" aria-label="A square with side length 2r, showing distance r from centre to edge" role="img">

    <!-- The square -->
    <rect x="80" y="50" width="240" height="240" fill="none" stroke="#555" stroke-width="2"/>

    <!-- Centre dot -->
    <circle cx="200" cy="170" r="3" fill="#555"/>

    <!-- Dimension line: full width along bottom (2r) -->
    <line x1="80" y1="310" x2="320" y2="310" stroke="#555" stroke-width="1.5"/>
    <line x1="80" y1="305" x2="80" y2="315" stroke="#555" stroke-width="1.5"/>
    <line x1="320" y1="305" x2="320" y2="315" stroke="#555" stroke-width="1.5"/>
    <foreignObject x="175" y="318" width="50" height="30">
      <span xmlns="http://www.w3.org/1999/xhtml" class="svg-katex" style="color:#333;display:block;text-align:center" set:html={k('2r')} />
    </foreignObject>

    <!-- Dimension line: r from centre to right edge -->
    <line x1="200" y1="170" x2="320" y2="170" stroke="#6366f1" stroke-width="2" stroke-dasharray="6,4"/>
    <foreignObject x="240" y="145" width="40" height="30">
      <span xmlns="http://www.w3.org/1999/xhtml" class="svg-katex" style="color:#6366f1" set:html={k('r')} />
    </foreignObject>

    <!-- Dimension line: full height along right (2r) -->
    <line x1="340" y1="50" x2="340" y2="290" stroke="#555" stroke-width="1.5"/>
    <line x1="335" y1="50" x2="345" y2="50" stroke="#555" stroke-width="1.5"/>
    <line x1="335" y1="290" x2="345" y2="290" stroke="#555" stroke-width="1.5"/>
    <foreignObject x="348" y="155" width="50" height="30">
      <span xmlns="http://www.w3.org/1999/xhtml" class="svg-katex" style="color:#333" set:html={k('2r')} />
    </foreignObject>

  </svg>
  <figcaption>{t.caption}</figcaption>
</figure>

<style>
  .pi-square {
    margin: 2rem 0;
  }

  .pi-square svg {
    display: block;
    width: 100%;
    max-width: 420px;
    height: auto;
    margin: 0 auto;
    border-radius: var(--radius);
    background: var(--color-bg-alt);
    padding: 1rem;
  }

  .pi-square figcaption {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-align: center;
    margin-top: 0.5rem;
  }

  .svg-katex {
    font-size: 14px;
    line-height: 1;
    white-space: nowrap;
  }

  .svg-katex :global(.katex) {
    font-size: 1em;
  }
</style>
