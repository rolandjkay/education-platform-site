---
// Static SVG: Circle sandwiched between an inscribed (inner) and circumscribed (outer)
// regular hexagon.  Shows the tighter bound 3.000 < π < 3.464.
import katex from 'katex';
const k = (tex: string) => katex.renderToString(tex, { throwOnError: false });

interface Props {
  locale?: string;
}
const { locale = 'en' } = Astro.props;

const labels: Record<string, Record<string, string>> = {
  en: {
    outerLabel: 'Outer hexagon: area \u2248 ',
    innerLabel: 'Inner hexagon: area \u2248 ',
    caption: 'The same idea with hexagons. The inner hexagon (red) has area \u2248 2.598r\u00B2 and the outer hexagon (grey) has area \u2248 3.464r\u00B2. The bounds are already much tighter.',
  },
  fr: {
    outerLabel: 'Hexagone extérieur : aire \u2248 ',
    innerLabel: 'Hexagone intérieur : aire \u2248 ',
    caption: 'La m\u00EAme id\u00E9e avec des hexagones. L\u2019hexagone int\u00E9rieur (rouge) a une aire \u2248 2,598r\u00B2 et l\u2019hexagone ext\u00E9rieur (gris) a une aire \u2248 3,464r\u00B2. Les bornes sont d\u00E9j\u00E0 bien plus resserr\u00E9es.',
  },
  de: {
    outerLabel: '\u00C4u\u00DFeres Sechseck: Fl\u00E4che \u2248 ',
    innerLabel: 'Inneres Sechseck: Fl\u00E4che \u2248 ',
    caption: 'Dieselbe Idee mit Sechsecken. Das innere Sechseck (rot) hat die Fl\u00E4che \u2248 2,598r\u00B2 und das \u00E4u\u00DFere Sechseck (grau) hat die Fl\u00E4che \u2248 3,464r\u00B2. Die Grenzen sind schon deutlich enger.',
  },
  es: {
    outerLabel: 'Hex\u00E1gono exterior: \u00E1rea \u2248 ',
    innerLabel: 'Hex\u00E1gono interior: \u00E1rea \u2248 ',
    caption: 'La misma idea con hex\u00E1gonos. El hex\u00E1gono interior (rojo) tiene un \u00E1rea \u2248 2,598r\u00B2 y el hex\u00E1gono exterior (gris) tiene un \u00E1rea \u2248 3,464r\u00B2. Los l\u00EDmites ya son mucho m\u00E1s ajustados.',
  },
  it: {
    outerLabel: 'Esagono esterno: area \u2248 ',
    innerLabel: 'Esagono interno: area \u2248 ',
    caption: 'La stessa idea con gli esagoni. L\u2019esagono interno (rosso) ha area \u2248 2,598r\u00B2 e l\u2019esagono esterno (grigio) ha area \u2248 3,464r\u00B2. I limiti sono gi\u00E0 molto pi\u00F9 stretti.',
  },
  'zh-CN': {
    outerLabel: '\u5916\u6B63\u516D\u8FB9\u5F62\uFF1A\u9762\u79EF \u2248 ',
    innerLabel: '\u5185\u6B63\u516D\u8FB9\u5F62\uFF1A\u9762\u79EF \u2248 ',
    caption: '\u540C\u6837\u7684\u601D\u8DEF\u7528\u6B63\u516D\u8FB9\u5F62\u6765\u5B9E\u73B0\u3002\u5185\u6B63\u516D\u8FB9\u5F62\uFF08\u7EA2\u8272\uFF09\u9762\u79EF \u2248 2.598r\u00B2\uFF0C\u5916\u6B63\u516D\u8FB9\u5F62\uFF08\u7070\u8272\uFF09\u9762\u79EF \u2248 3.464r\u00B2\u3002\u8303\u56F4\u5DF2\u7ECF\u7D27\u5F97\u591A\u4E86\u3002',
  },
  'zh-TW': {
    outerLabel: '\u5916\u6B63\u516D\u908A\u5F62\uFF1A\u9762\u7A4D \u2248 ',
    innerLabel: '\u5167\u6B63\u516D\u908A\u5F62\uFF1A\u9762\u7A4D \u2248 ',
    caption: '\u540C\u6A23\u7684\u601D\u8DEF\u7528\u6B63\u516D\u908A\u5F62\u4F86\u5BE6\u73FE\u3002\u5167\u6B63\u516D\u908A\u5F62\uFF08\u7D05\u8272\uFF09\u9762\u7A4D \u2248 2.598r\u00B2\uFF0C\u5916\u6B63\u516D\u908A\u5F62\uFF08\u7070\u8272\uFF09\u9762\u7A4D \u2248 3.464r\u00B2\u3002\u7BC4\u570D\u5DF2\u7D93\u7DCA\u5F97\u591A\u4E86\u3002',
  },
  ja: {
    outerLabel: '\u5916\u5074\u306E\u6B63\u516D\u89D2\u5F62\uFF1A\u9762\u7A4D \u2248 ',
    innerLabel: '\u5185\u5074\u306E\u6B63\u516D\u89D2\u5F62\uFF1A\u9762\u7A4D \u2248 ',
    caption: '\u540C\u3058\u8003\u3048\u65B9\u3092\u6B63\u516D\u89D2\u5F62\u3067\u884C\u3044\u307E\u3059\u3002\u5185\u5074\u306E\u6B63\u516D\u89D2\u5F62\uFF08\u8D64\uFF09\u306E\u9762\u7A4D\u306F \u2248 2.598r\u00B2\u3001\u5916\u5074\u306E\u6B63\u516D\u89D2\u5F62\uFF08\u7070\u8272\uFF09\u306E\u9762\u7A4D\u306F \u2248 3.464r\u00B2 \u3067\u3059\u3002\u7BC4\u56F2\u304C\u3059\u3067\u306B\u304B\u306A\u308A\u72ED\u307E\u3063\u3066\u3044\u307E\u3059\u3002',
  },
};

const t = { ...labels.en, ...(labels[locale] ?? {}) };

// ── geometry ───────────────────────────────────────────────────────────
const CX = 250, CY = 200, R = 120;
const R_OUTER = R / Math.cos(Math.PI / 6);          // ≈ 138.56

// Inner hexagon — vertex-up (first vertex at top)
const innerPts = Array.from({ length: 6 }, (_, i) => {
  const a = -Math.PI / 2 + i * Math.PI / 3;
  return `${Math.round(CX + R * Math.cos(a))},${Math.round(CY + R * Math.sin(a))}`;
}).join(' ');

// Outer hexagon — rotated 30° so flat sides face the circle
const outerPts = Array.from({ length: 6 }, (_, i) => {
  const a = -Math.PI / 3 + i * Math.PI / 3;
  return `${Math.round(CX + R_OUTER * Math.cos(a))},${Math.round(CY + R_OUTER * Math.sin(a))}`;
}).join(' ');
---

<figure class="diagram pi-hex">
  <svg xmlns="http://www.w3.org/2000/svg" width="100%" viewBox="0 0 500 430"
       aria-label="Circle with inscribed and circumscribed hexagons, showing the bound 3 < pi < 3.464" role="img">

    <!-- Outer hexagon -->
    <polygon points={outerPts} fill="none" stroke="#555" stroke-width="2"/>

    <!-- Circle -->
    <circle cx={CX} cy={CY} r={R} fill="none" stroke="#6366f1" stroke-width="2"/>

    <!-- Inner hexagon -->
    <polygon points={innerPts} fill="#6366f1" opacity="0.08" stroke="#d63030" stroke-width="2"/>

    <!-- Centre dot -->
    <circle cx={CX} cy={CY} r="3" fill="#555"/>

    <!-- Radius line -->
    <line x1={CX} y1={CY} x2={CX + R} y2={CY} stroke="#6366f1" stroke-width="2" stroke-dasharray="6,4"/>
    <foreignObject x={CX + R / 2 - 20} y={CY - 25} width="40" height="30">
      <span xmlns="http://www.w3.org/1999/xhtml" class="svg-katex" style="color:#6366f1;display:block;text-align:center" set:html={k('r')} />
    </foreignObject>

    <!-- Corner dots where inner hexagon meets circle -->
    {Array.from({ length: 6 }, (_, i) => {
      const a = -Math.PI / 2 + i * Math.PI / 3;
      return <circle cx={Math.round(CX + R * Math.cos(a))} cy={Math.round(CY + R * Math.sin(a))} r="4" fill="#d63030"/>;
    })}

    <!-- Labels -->
    <foreignObject x="120" y="32" width="260" height="30">
      <span xmlns="http://www.w3.org/1999/xhtml" class="svg-katex svg-katex-sm" style="color:#555">
        {t.outerLabel}<span set:html={k('3.464\\,r^2')} />
      </span>
    </foreignObject>
    <foreignObject x="100" y="382" width="300" height="30">
      <span xmlns="http://www.w3.org/1999/xhtml" class="svg-katex svg-katex-sm" style="color:#d63030;display:block;text-align:center">
        {t.innerLabel}<span set:html={k('2.598\\,r^2')} />
      </span>
    </foreignObject>

    <!-- Summary bound -->
    <foreignObject x="130" y="402" width="240" height="35">
      <span xmlns="http://www.w3.org/1999/xhtml" class="svg-katex" style="color:#333;display:block;text-align:center" set:html={k('3.000 < \\pi < 3.464')} />
    </foreignObject>

  </svg>
  <figcaption>{t.caption}</figcaption>
</figure>

<style>
  .pi-hex {
    margin: 2rem 0;
  }

  .pi-hex svg {
    display: block;
    width: 100%;
    max-width: 420px;
    height: auto;
    margin: 0 auto;
    border-radius: var(--radius);
    background: var(--color-bg-alt);
    padding: 1rem;
  }

  .pi-hex figcaption {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-align: center;
    margin-top: 0.5rem;
  }

  .svg-katex {
    font-size: 14px;
    line-height: 1;
    white-space: nowrap;
  }

  .svg-katex-sm {
    font-size: 12px;
  }

  .svg-katex :global(.katex) {
    font-size: 1em;
  }
</style>
