---
// Static SVG: Circle with both an outer square (side 2r) and an inner square (rotated 45°,
// corners touching the circle). Shows the Pythagoras construction and the bound 2 < π < 4.
// Labels rendered with KaTeX via foreignObject for consistent maths typography.

import katex from 'katex';

const k = (tex: string) => katex.renderToString(tex, { throwOnError: false });

interface Props {
  locale?: string;
}
const { locale = 'en' } = Astro.props;

const labels: Record<string, Record<string, string>> = {
  en: {
    outerLabel: 'Outer square: area = ',
    innerLabel: 'Inner square: area = ',
    caption: 'A circle of radius r sandwiched between two squares. The outer square (grey) has area 4r\u00B2. The inner square (red, rotated 45\u00B0) has area 2r\u00B2. The circle\u2019s area is somewhere in between, so 2 < \u03C0 < 4.',
  },
  fr: {
    outerLabel: 'Carré extérieur : aire = ',
    innerLabel: 'Carré intérieur : aire = ',
    caption: 'Un cercle de rayon r pris en sandwich entre deux carrés. Le carré extérieur (gris) a une aire de 4r\u00B2. Le carré intérieur (rouge, tourné à 45\u00B0) a une aire de 2r\u00B2. L\u2019aire du cercle se situe entre les deux, donc 2 < \u03C0 < 4.',
  },
  de: {
    outerLabel: 'Äußeres Quadrat: Fläche = ',
    innerLabel: 'Inneres Quadrat: Fläche = ',
    caption: 'Ein Kreis mit Radius r zwischen zwei Quadraten. Das äußere Quadrat (grau) hat die Fläche 4r\u00B2. Das innere Quadrat (rot, um 45\u00B0 gedreht) hat die Fläche 2r\u00B2. Die Kreisfläche liegt dazwischen, also 2 < \u03C0 < 4.',
  },
  es: {
    outerLabel: 'Cuadrado exterior: área = ',
    innerLabel: 'Cuadrado interior: área = ',
    caption: 'Un círculo de radio r entre dos cuadrados. El cuadrado exterior (gris) tiene un área de 4r\u00B2. El cuadrado interior (rojo, girado 45\u00B0) tiene un área de 2r\u00B2. El área del círculo está en medio, por tanto 2 < \u03C0 < 4.',
  },
  it: {
    outerLabel: 'Quadrato esterno: area = ',
    innerLabel: 'Quadrato interno: area = ',
    caption: 'Un cerchio di raggio r racchiuso tra due quadrati. Il quadrato esterno (grigio) ha area 4r\u00B2. Il quadrato interno (rosso, ruotato di 45\u00B0) ha area 2r\u00B2. L\u2019area del cerchio \u00E8 compresa tra i due, quindi 2 < \u03C0 < 4.',
  },
  'zh-CN': {
    outerLabel: '外正方形：面积 = ',
    innerLabel: '内正方形：面积 = ',
    caption: '一个半径为 r 的圆夹在两个正方形之间。外正方形（灰色）面积为 4r\u00B2。内正方形（红色，旋转 45\u00B0）面积为 2r\u00B2。圆的面积介于两者之间，因此 2 < \u03C0 < 4。',
  },
  'zh-TW': {
    outerLabel: '外正方形：面積 = ',
    innerLabel: '內正方形：面積 = ',
    caption: '一個半徑為 r 的圓夾在兩個正方形之間。外正方形（灰色）面積為 4r\u00B2。內正方形（紅色，旋轉 45\u00B0）面積為 2r\u00B2。圓的面積介於兩者之間，因此 2 < \u03C0 < 4。',
  },
  ja: {
    outerLabel: '外側の正方形：面積 = ',
    innerLabel: '内側の正方形：面積 = ',
    caption: '半径 r の円が 2 つの正方形に挟まれています。外側の正方形（灰色）の面積は 4r\u00B2、内側の正方形（赤、45\u00B0 回転）の面積は 2r\u00B2 です。円の面積はその間にあるので、2 < \u03C0 < 4 です。',
  },
};

const t = { ...labels.en, ...(labels[locale] ?? {}) };
---

<figure class="diagram pi-sq-circ">
  <svg xmlns="http://www.w3.org/2000/svg" width="100%" viewBox="0 0 500 430" aria-label="Circle with inscribed and circumscribed squares, showing the Pythagoras construction for bounding pi" role="img">

    <!-- Outer square -->
    <rect x="130" y="60" width="240" height="240" fill="none" stroke="#555" stroke-width="2"/>

    <!-- Circle -->
    <circle cx="250" cy="180" r="120" fill="none" stroke="#6366f1" stroke-width="2"/>

    <!-- Inner square (rotated 45°) -->
    <polygon points="250,60 370,180 250,300 130,180" fill="#6366f1" opacity="0.08" stroke="#d63030" stroke-width="2"/>

    <!-- Centre dot -->
    <circle cx="250" cy="180" r="3" fill="#555"/>

    <!-- Radius line from centre to right corner of inner square -->
    <line x1="250" y1="180" x2="370" y2="180" stroke="#6366f1" stroke-width="2" stroke-dasharray="6,4"/>
    <foreignObject x="290" y="155" width="40" height="30">
      <span xmlns="http://www.w3.org/1999/xhtml" class="svg-katex" style="color:#6366f1" set:html={k('r')} />
    </foreignObject>

    <!-- Pythagoras construction lines -->
    <line x1="250" y1="180" x2="370" y2="180" stroke="#aaa" stroke-width="1" stroke-dasharray="4,3"/>
    <line x1="370" y1="180" x2="250" y2="60" stroke="#aaa" stroke-width="1" stroke-dasharray="4,3"/>

    <!-- Vertical line from centre to top corner = r -->
    <line x1="250" y1="180" x2="250" y2="60" stroke="#d63030" stroke-width="1.5" stroke-dasharray="5,4"/>
    <foreignObject x="218" y="110" width="30" height="30">
      <span xmlns="http://www.w3.org/1999/xhtml" class="svg-katex" style="color:#d63030" set:html={k('r')} />
    </foreignObject>

    <!-- Right angle marker at centre -->
    <rect x="250" y="168" width="12" height="12" fill="none" stroke="#aaa" stroke-width="1"/>

    <!-- Corner dots where inner square meets circle -->
    <circle cx="250" cy="60" r="4" fill="#d63030"/>
    <circle cx="370" cy="180" r="4" fill="#d63030"/>
    <circle cx="250" cy="300" r="4" fill="#d63030"/>
    <circle cx="130" cy="180" r="4" fill="#d63030"/>

    <!-- Labels for each square -->
    <foreignObject x="125" y="32" width="220" height="30">
      <span xmlns="http://www.w3.org/1999/xhtml" class="svg-katex svg-katex-sm" style="color:#555">
        {t.outerLabel}<span set:html={k('4r^2')} />
      </span>
    </foreignObject>
    <foreignObject x="140" y="382" width="220" height="30">
      <span xmlns="http://www.w3.org/1999/xhtml" class="svg-katex svg-katex-sm" style="color:#d63030;display:block;text-align:center">
        {t.innerLabel}<span set:html={k('2r^2')} />
      </span>
    </foreignObject>

    <!-- Summary bound -->
    <foreignObject x="160" y="402" width="180" height="35">
      <span xmlns="http://www.w3.org/1999/xhtml" class="svg-katex" style="color:#333;display:block;text-align:center" set:html={k('2 < \\pi < 4')} />
    </foreignObject>

  </svg>
  <figcaption>{t.caption}</figcaption>
</figure>

<style>
  .pi-sq-circ {
    margin: 2rem 0;
  }

  .pi-sq-circ svg {
    display: block;
    width: 100%;
    max-width: 420px;
    height: auto;
    margin: 0 auto;
    border-radius: var(--radius);
    background: var(--color-bg-alt);
    padding: 1rem;
  }

  .pi-sq-circ figcaption {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-align: center;
    margin-top: 0.5rem;
  }

  .svg-katex {
    font-size: 14px;
    line-height: 1;
    white-space: nowrap;
  }

  .svg-katex-sm {
    font-size: 12px;
  }

  .svg-katex :global(.katex) {
    font-size: 1em;
  }
</style>
