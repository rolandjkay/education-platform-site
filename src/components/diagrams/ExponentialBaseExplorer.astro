---
// Interactive diagram: y = a^x vs y = e^x
// Slider lets user adjust base a; snaps to e = 2.71828…
// Tangent line at x=1 on both curves shows dy/dx = k·y, with k = ln(a).
// When a = e, k = 1 and the curves coincide.

interface Props {
  locale?: string;
}

const { locale = 'en' } = Astro.props;

const labels: Record<string, Record<string, string>> = {
  en: {
    sliderLabel:  '<em>a</em>&nbsp;=&nbsp;',
    formulaLabel: 'At&nbsp;t&nbsp;=&nbsp;1:&nbsp;&nbsp;slope&nbsp;of&nbsp;red&nbsp;=&nbsp;',
    snapHint: '\u2190 matches grey (slope\u00A0=\u00A0e\u00A0\u2248\u00A02.718)',
    caption: 'Drag the slider to change the value of <em>a</em> of the red curve y&nbsp;=&nbsp;a<sup>t</sup>. The grey curve is y&nbsp;=&nbsp;e<sup>t</sup>. The lines show the tangent for both functions, giving the rate of growth at that point. The corresponding value of k is labelled.',
  },
  fr: {
    sliderLabel:  'Base <em>a</em>&nbsp;=&nbsp;',
    formulaLabel: 'En&nbsp;t&nbsp;=&nbsp;1&nbsp;:&nbsp;&nbsp;pente&nbsp;du&nbsp;rouge&nbsp;=&nbsp;',
    snapHint: '\u2190 correspond \u00E0 la grise (pente\u00A0=\u00A0e\u00A0\u2248\u00A02,718)',
    caption: 'Faites glisser le curseur pour modifier la valeur de <em>a</em> de la courbe rouge y&nbsp;=&nbsp;a<sup>t</sup>. La courbe grise est y&nbsp;=&nbsp;e<sup>t</sup>. Les droites sont les tangentes aux deux courbes, indiquant le taux de croissance en ce point. La valeur correspondante de k est indiquée.',
  }
};

const t = { ...labels.en, ...(labels[locale] ?? {}) };
---

<figure class="diagram exp-diagram">
  <svg id="exp-svg" xmlns="http://www.w3.org/2000/svg"
       width="100%" viewBox="0 0 500 300" preserveAspectRatio="xMinYMin meet"
       data-snap-hint={t.snapHint}>
    <defs>
      <clipPath id="exp-plot-clip">
        <!-- Covers the plot region (PL=55, PT=15, PW=430, PH=245) -->
        <rect x="55" y="14" width="431" height="247"/>
      </clipPath>
    </defs>
    <!-- Content rendered by the <script> below -->
  </svg>

  <div class="exp-controls">
    <div class="exp-slider-row">
      <label for="exp-a-slider"><span set:html={t.sliderLabel} /><strong id="exp-a-display">2.00</strong></label>
      <input id="exp-a-slider" type="range"
             min="1.1" max="4.0" step="0.01" value="2.00"
             list="exp-a-ticks" class="exp-range">
      <datalist id="exp-a-ticks">
        <option value="2.71828"></option>
      </datalist>
    </div>
    <div class="exp-formula">
      <span set:html={t.formulaLabel} /><strong id="exp-k-display">1.39</strong>
      <span id="exp-snap-hint" class="exp-snap-hint"></span>
    </div>
  </div>

  <figcaption set:html={t.caption} />
</figure>

<style>
  .exp-diagram {
    margin: 2rem 0;
  }

  .exp-diagram svg {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    background: var(--color-bg-alt);
    padding: 1rem;
    box-sizing: border-box;
  }

  /* KaTeX inside foreignObject — override KaTeX's default 1.21em font scale */
  .exp-fo-lbl .katex { font-size: 1em; }

  .exp-controls {
    padding: 0.75rem 1rem 0.25rem;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .exp-slider-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.4rem;
  }

  .exp-range {
    flex: 1;
    min-width: 160px;
    accent-color: var(--color-primary);
  }

  .exp-formula {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .exp-snap-hint {
    margin-left: 0.5rem;
    color: var(--color-primary, #2a7ae2);
    font-weight: 600;
  }

  .exp-diagram figcaption {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-align: center;
    margin-top: 0.5rem;
  }
</style>

<script>
import { renderToString } from 'katex';

(function () {
  'use strict';

  const E    = Math.E;   // 2.71828…
  const SNAP = 0.15;     // snap slider to e if within this range

  // ── Coordinate system (matches viewBox 0 0 500 300) ────────────────
  const PL = 55, PT = 15, PB = 40, PR = 15;
  const PW = 500 - PL - PR;  // 430 px
  const PH = 300 - PT - PB;  // 245 px
  const XL = -2, XR = 3;     // math x range [-2, 3]
  const YB = 0,  YT = 8;     // math y range [0, 8]
  const SX = PW / (XR - XL); // 86 px / x-unit
  const SY = PH / (YT - YB); // 30.625 px / y-unit

  const tx = (x) => PL + (x - XL) * SX;
  const ty = (y) => PT + PH - (y - YB) * SY;

  const NS   = 'http://www.w3.org/2000/svg';
  const XHNS = 'http://www.w3.org/1999/xhtml';
  const svg  = document.getElementById('exp-svg');
  if (!svg) return;
  const snapHintText = svg.dataset.snapHint || '';

  // Convenience helpers
  function mk(tag, attrs, parent) {
    const e = document.createElementNS(NS, tag);
    if (attrs) for (const [k, v] of Object.entries(attrs)) e.setAttribute(k, String(v));
    if (parent) parent.appendChild(e);
    return e;
  }
  function mkTxt(content, attrs, parent) {
    const e = mk('text', attrs, parent);
    e.textContent = content;
    return e;
  }

  // ── Create a <foreignObject> KaTeX label at SVG coordinates (x, y) ──
  // Labels are placed in SVG space — no JS coordinate conversion needed.
  // The HTML inside renders at fixed CSS pixel sizes (not SVG-scaled),
  // which keeps text readable at any container width.
  function mkFO(svgX, svgY, html, color) {
    const fo  = document.createElementNS(NS, 'foreignObject');
    fo.setAttribute('x',      svgX);
    fo.setAttribute('y',      svgY);
    fo.setAttribute('width',  '200');
    fo.setAttribute('height', '22');
    fo.setAttribute('overflow', 'visible');
    const div = document.createElementNS(XHNS, 'div');
    div.className = 'exp-fo-lbl';
    div.style.cssText = `color:${color};font-size:0.7rem;line-height:1;white-space:nowrap;`;
    div.innerHTML = html;
    fo.appendChild(div);
    svg.appendChild(fo);
    return { fo, div };  // fo for position updates, div for innerHTML updates
  }

  // ── Build static elements: grid, axes, tick labels ──────────────────
  // Grid
  const grid = mk('g', { stroke: '#e6e6e6', 'stroke-width': '1', 'shape-rendering': 'crispEdges' }, svg);
  for (let xi = XL; xi <= XR; xi++)
    mk('line', { x1: tx(xi), y1: PT, x2: tx(xi), y2: PT + PH }, grid);
  for (let yi = 2; yi <= YT; yi += 2)
    mk('line', { x1: PL, y1: ty(yi), x2: PL + PW, y2: ty(yi) }, grid);

  // Axes
  const axes = mk('g', { stroke: '#444', 'stroke-width': '1.5', 'shape-rendering': 'crispEdges' }, svg);
  mk('line', { x1: PL,    y1: ty(0),   x2: PL + PW, y2: ty(0)    }, axes); // x-axis
  mk('line', { x1: tx(0), y1: PT,      x2: tx(0),   y2: PT + PH  }, axes); // y-axis
  // Arrowheads
  mk('path', { d: `M${PL+PW-8},${ty(0)-4} L${PL+PW},${ty(0)} L${PL+PW-8},${ty(0)+4}Z`, fill: '#444', stroke: 'none' }, axes);
  mk('path', { d: `M${tx(0)-4},${PT+8}    L${tx(0)},${PT}    L${tx(0)+4},${PT+8}Z`,    fill: '#444', stroke: 'none' }, axes);

  // Tick marks and numeric labels
  const tg = mk('g', { 'font-size': '11', 'font-family': 'sans-serif', fill: '#666' }, svg);
  for (let xi = XL; xi <= XR; xi++) {
    if (xi === 0) continue;
    mk('line', { x1: tx(xi), y1: ty(0)-3, x2: tx(xi), y2: ty(0)+3, stroke: '#444', 'stroke-width': '1' }, tg);
    mkTxt(xi, { x: tx(xi), y: ty(0)+15, 'text-anchor': 'middle' }, tg);
  }
  for (let yi = 2; yi <= YT; yi += 2) {
    mk('line', { x1: tx(0)-3, y1: ty(yi), x2: tx(0)+3, y2: ty(yi), stroke: '#444', 'stroke-width': '1' }, tg);
    mkTxt(yi, { x: tx(0)-6, y: ty(yi)+4, 'text-anchor': 'end' }, tg);
  }
  // Axis name labels
  mkTxt('t', { x: PL+PW+6, y: ty(0)+4,  'font-size': '13', 'font-style': 'italic', 'font-family': 'serif', fill: '#444' }, tg);
  mkTxt('y', { x: tx(0)+5, y: PT+12,    'font-size': '13', 'font-style': 'italic', 'font-family': 'serif', fill: '#444' }, tg);

  // ── Path sampler ────────────────────────────────────────────────────
  function buildPath(fn) {
    const STEPS = 300;
    const parts = [];
    let move = true;
    for (let i = 0; i <= STEPS; i++) {
      const x = XL + (XR - XL) * i / STEPS;
      const y = fn(x);
      if (y < YB - 0.3 || y > YT + 0.5) { move = true; continue; }
      parts.push((move ? 'M' : 'L') + tx(x).toFixed(1) + ',' + ty(y).toFixed(1));
      move = false;
    }
    return parts.join(' ');
  }

  // ── Grey e^x curve (static) ─────────────────────────────────────────
  mk('path', {
    fill: 'none', stroke: '#c0c0c0', 'stroke-width': '2.5',
    'clip-path': 'url(#exp-plot-clip)',
    d: buildPath(Math.exp),
  }, svg);

  // ── Grey tangent line at t = 1 (static) ────────────────────────────
  // e^x at x=1: y = e, slope = e.  Tangent extends ±0.65 in x.
  {
    const DX   = 0.65;
    const x0   = 1, y0 = Math.E, m = Math.E;
    const g = mk('g', { 'clip-path': 'url(#exp-plot-clip)' }, svg);
    mk('line', { x1: tx(x0-DX), y1: ty(y0-m*DX), x2: tx(x0+DX), y2: ty(y0+m*DX),
                 stroke: '#c8c8c8', 'stroke-width': '1.5' }, g);
    mk('circle', { cx: tx(x0), cy: ty(y0), r: '4', fill: '#b0b0b0' }, g);
  }

  // ── Red t curve (dynamic) ─────────────────────────────────────────
  const redPath = mk('path', {
    fill: 'none', stroke: '#d63030', 'stroke-width': '2',
    'clip-path': 'url(#exp-plot-clip)',
  }, svg);

  // ── Red tangent line elements (dynamic) ─────────────────────────────
  const rdTangentGroup = mk('g', { 'clip-path': 'url(#exp-plot-clip)' }, svg);
  const rdTangent = mk('line', { stroke: '#d63030', 'stroke-width': '1.5' }, rdTangentGroup);
  const rdDot     = mk('circle', { r: '4', fill: '#d63030' }, rdTangentGroup);

  // ── KaTeX labels near the tangent dots at x = 1 ────────────────────
  // Grey dot is fixed at SVG (313, 177).  Labels sit 10 px to its right.
  // Red dot moves vertically; its labels' y is updated in update().
  // tx(1) = 313, ty(E) ≈ 177.  Label x = 323 is past the tangent line
  // extent so labels never overlap either tangent segment.
  mkFO(243, 162, renderToString('y = e^t',       { throwOnError: false }), '#999');
  mkFO(243, 177, renderToString('k = 1.00', { throwOnError: false }), '#999');
  const { fo: redCurveFo, div: redCurveDiv } = mkFO(353, 184, '', '#d63030');
  const { fo: redSlopeFo, div: redSlopeDiv } = mkFO(353, 199, '', '#c02020');

  // ── Update function (called on each slider change) ──────────────────
  function update(a) {
    const isE = Math.abs(a - E) < 0.001;
    const k   = Math.log(a); // ln(a); = 1 when a = e

    // Replot red curve
    redPath.setAttribute('d', buildPath((x) => Math.pow(a, x)));

    // Red tangent line at x = 1
    const DX    = 0.65;
    const x0    = 1;
    const y0    = Math.pow(a, x0);   // a^1 = a
    const slope = k * y0;            // ln(a) · a

    rdTangent.setAttribute('x1', tx(x0 - DX)); rdTangent.setAttribute('y1', ty(y0 - slope * DX));
    rdTangent.setAttribute('x2', tx(x0 + DX)); rdTangent.setAttribute('y2', ty(y0 + slope * DX));
    rdDot.setAttribute('cx', tx(x0));
    rdDot.setAttribute('cy', ty(y0));

    // Dynamic KaTeX labels — track the red dot vertically
    const redDotY = ty(a);
    redCurveFo.setAttribute('y', String(redDotY - 15));
    redSlopeFo.setAttribute('y', String(redDotY));
    redCurveDiv.innerHTML = renderToString(isE ? 'y = a^t' : 'y = a^t', { throwOnError: false });
    redSlopeDiv.innerHTML = renderToString('k = ' + k.toFixed(2), { throwOnError: false });

    // Control-panel readout
    const slope1 = k * a; // dy/dx of a^t at t=1
    document.getElementById('exp-a-display').textContent = isE ? 'e \u2248 2.718' : a.toFixed(2);
    document.getElementById('exp-k-display').textContent = isE ? 'e \u2248 2.718' : slope1.toFixed(2);
    const hint = document.getElementById('exp-snap-hint');
    hint.textContent = isE ? snapHintText : '';
  }

  // ── Slider with snap-to-e ────────────────────────────────────────────
  const slider = document.getElementById('exp-a-slider');
  slider.addEventListener('input', function () {
    let a = parseFloat(this.value);
    if (Math.abs(a - E) < SNAP) {
      a = E;
      this.value = String(E);
    }
    update(a);
  });

  // ── Initial render ───────────────────────────────────────────────────
  update(parseFloat(slider.value));
})();
</script>
