---
// Animated Three.js diagram: spherical cap vs flat disc area comparison.
// Looping animation shows that a circle on a curved surface encloses more area
// than a flat circle with the same boundary, giving a different "effective π".
//
// Animation sequence:
//   1. Full sphere visible (2 s)
//   2. Bottom hemisphere fades out (1 s)
//   3. Flat disc separates downward (1.5 s)
//   4. Formula labels + arrows fade in (1.5 s)
//   5. π values fade in below canvas (1.5 s)
//   6. Hold (20 s)
//   7. Fade out everything (1.5 s), reset, repeat

interface Props {
  locale?: string;
}
const { locale = 'en' } = Astro.props;

const labels: Record<string, Record<string, string>> = {
  en: {
    surface: 'surface',
    disc: 'disc',
    caption: 'A circle on a curved surface (indigo) encloses more area than the flat disc (red) bounded by the same circumference. On a sphere, the effective \u201C\u03C0\u201D is different from 3.14.',
  },
  fr: {
    surface: 'surface',
    disc: 'disque',
    caption: 'Un cercle sur une surface courbe (indigo) renferme plus d\u2019aire que le disque plat (rouge) de m\u00EAme circonf\u00E9rence. Sur une sph\u00E8re, le \u00AB \u03C0 effectif \u00BB diff\u00E8re de 3,14.',
  },
  de: {
    surface: 'Fl\u00E4che',
    disc: 'Scheibe',
    caption: 'Ein Kreis auf einer gekr\u00FCmmten Fl\u00E4che (Indigo) umschlie\u00DFt mehr Fl\u00E4che als die flache Scheibe (rot) mit demselben Umfang. Auf einer Kugel weicht das effektive \u201E\u03C0\u201C von 3,14 ab.',
  },
  es: {
    surface: 'superficie',
    disc: 'disco',
    caption: 'Un c\u00EDrculo sobre una superficie curva (\u00EDndigo) encierra m\u00E1s \u00E1rea que el disco plano (rojo) con la misma circunferencia. En una esfera, el \u00AB\u03C0 efectivo\u00BB es distinto de 3,14.',
  },
  it: {
    surface: 'superficie',
    disc: 'disco',
    caption: 'Un cerchio su una superficie curva (indaco) racchiude pi\u00F9 area del disco piatto (rosso) con la stessa circonferenza. Su una sfera, il \u00AB\u03C0 effettivo\u00BB \u00E8 diverso da 3,14.',
  },
  'zh-CN': {
    surface: '\u66F2\u9762',
    disc: '\u5706\u76D8',
    caption: '\u5F2F\u66F2\u9762\u4E0A\u7684\u5706\uFF08\u9756\u9752\u8272\uFF09\u6240\u56F4\u7684\u9762\u79EF\u5927\u4E8E\u76F8\u540C\u5468\u957F\u7684\u5E73\u9762\u5706\u76D8\uFF08\u7EA2\u8272\uFF09\u3002\u5728\u7403\u9762\u4E0A\uFF0C\u7B49\u6548\u201C\u03C0\u201D\u4E0E3.14\u4E0D\u540C\u3002',
  },
  'zh-TW': {
    surface: '\u66F2\u9762',
    disc: '\u5713\u76E4',
    caption: '\u5F4E\u66F2\u9762\u4E0A\u7684\u5713\uFF08\u9756\u9752\u8272\uFF09\u6240\u570D\u7684\u9762\u7A4D\u5927\u65BC\u76F8\u540C\u5468\u9577\u7684\u5E73\u9762\u5713\u76E4\uFF08\u7D05\u8272\uFF09\u3002\u5728\u7403\u9762\u4E0A\uFF0C\u7B49\u6548\u300C\u03C0\u300D\u8207 3.14 \u4E0D\u540C\u3002',
  },
  ja: {
    surface: '\u66F2\u9762',
    disc: '\u5186\u76E4',
    caption: '\u66F2\u9762\u4E0A\u306E\u5186\uFF08\u85CD\u8272\uFF09\u306F\u3001\u540C\u3058\u5186\u5468\u306E\u5E73\u9762\u5186\u76E4\uFF08\u8D64\uFF09\u3088\u308A\u5E83\u3044\u9762\u7A4D\u3092\u56F2\u307F\u307E\u3059\u3002\u7403\u9762\u3067\u306F\u5B9F\u52B9\u7684\u306A\u300C\u03C0\u300D\u306F 3.14 \u3068\u306F\u7570\u306A\u308A\u307E\u3059\u3002',
  },
};

const t = { ...labels.en, ...(labels[locale] ?? {}) };
---

<figure class="diagram cap-diagram">
  <div class="cap-viewport" id="cap-viewport">
    <canvas id="cap-canvas"></canvas>

    <!-- SVG overlay for arrow lines from labels to 3D objects -->
    <svg id="cap-svg" class="cap-svg" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <marker id="ah-cap" viewBox="0 0 10 10" refX="9" refY="5"
                markerWidth="7" markerHeight="7" orient="auto-start-reverse">
          <path d="M0,1 L9,5 L0,9z" fill="#6366f1"/>
        </marker>
        <marker id="ah-disc" viewBox="0 0 10 10" refX="9" refY="5"
                markerWidth="7" markerHeight="7" orient="auto-start-reverse">
          <path d="M0,1 L9,5 L0,9z" fill="#d63030"/>
        </marker>
      </defs>
      <line id="arrow-cap" stroke="#6366f1" stroke-width="1.5" marker-end="url(#ah-cap)"/>
      <line id="arrow-disc" stroke="#d63030" stroke-width="1.5" marker-end="url(#ah-disc)"/>
    </svg>

    <!-- Formula labels (positioned by JS) -->
    <div id="cap-lbl-cap" class="cap-formula cap-color-cap">
      <em>A</em><sub>{t.surface}</sub>&nbsp;=&nbsp;<strong>3.68</strong>&thinsp;×&thinsp;<em>r</em>&thinsp;²
    </div>
    <div id="cap-lbl-disc" class="cap-formula cap-color-disc">
      <em>A</em><sub>{t.disc}</sub>&nbsp;=&nbsp;<strong>3.14</strong>&thinsp;×&thinsp;<em>r</em>&thinsp;²
    </div>
  </div>

  <!-- π values row (below the 3D viewport) -->
  <div id="cap-pi-row" class="cap-pi-row">
    <span class="cap-color-cap">
      <em>π</em><sub>{t.surface}</sub>&nbsp;=&nbsp;<strong>3.68</strong>
    </span>
    <span class="cap-color-disc">
      <em>π</em><sub>{t.disc}</sub>&nbsp;=&nbsp;<strong>3.14</strong>
    </span>
  </div>

  <figcaption>{t.caption}</figcaption>
</figure>

<style>
  .cap-diagram {
    margin: 2rem 0;
  }

  .cap-viewport {
    position: relative;
    line-height: 0;
  }

  #cap-canvas {
    display: block;
    width: 100%;
    height: 400px;
    border-radius: var(--radius, 12px);
    background: var(--color-bg-alt, #f9fafb);
  }

  /* SVG overlay — sits on top of canvas for arrow lines */
  .cap-svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    overflow: visible;
  }

  .cap-svg line {
    opacity: 0;
    transition: none;
  }

  /* Formula labels — positioned absolutely by JS */
  .cap-formula {
    position: absolute;
    pointer-events: none;
    white-space: nowrap;
    font-family: var(--font-sans, 'Source Sans 3', system-ui, sans-serif);
    font-size: 0.95rem;
    line-height: 1.3;
    opacity: 0;
    padding: 0.2em 0.5em;
    border-radius: 4px;
    background: rgba(255,255,255,0.85);
  }

  .cap-color-cap, .cap-color-cap strong { color: #6366f1; }
  .cap-color-disc, .cap-color-disc strong { color: #d63030; }

  /* π values row below the viewport */
  .cap-pi-row {
    display: flex;
    justify-content: center;
    gap: 2rem;
    padding: 0.6rem 1rem;
    font-family: var(--font-sans, 'Source Sans 3', system-ui, sans-serif);
    font-size: 1.05rem;
    opacity: 0;
  }

  .cap-diagram figcaption {
    font-family: var(--font-sans, 'Source Sans 3', system-ui, sans-serif);
    font-size: 0.875rem;
    color: var(--color-text-muted, #6b7280);
    text-align: center;
    margin-top: 0.5rem;
  }
</style>

<script>
  import * as THREE from 'three';
  /* ── Constants ────────────────────────────────────────────── */
  const THETA_DEG = 45;
  const THETA     = THREE.MathUtils.degToRad(THETA_DEG);
  const R         = 1;                        // sphere radius
  const R_CIRCLE  = R * Math.sin(THETA);      // boundary circle radius
  const Y_DISC_ORIG = R * Math.cos(THETA);    // original disc y position
  const DISC_DROP   = 1.3;                    // how far the disc separates downward

  /* ── Timeline (seconds) ───────────────────────────────────── */
  const T_FADE_START      = 2;
  const T_FADE_END        = 3;
  const T_SEPARATE_START  = 3;
  const T_SEPARATE_END    = 4.5;
  const T_FORMULAS_START  = 4.5;
  const T_FORMULAS_END    = 6;
  const T_PI_START        = 6;
  const T_PI_END          = 7.5;
  const T_FADEOUT_START   = 27.5;
  const T_FADEOUT_END     = 29;
  const T_CYCLE           = 30;

  /* ── DOM refs ─────────────────────────────────────────────── */
  const canvas    = document.getElementById('cap-canvas') as HTMLCanvasElement;
  const viewport  = document.getElementById('cap-viewport')!;
  const svgEl     = document.getElementById('cap-svg')!;
  const arrowCap  = document.getElementById('arrow-cap') as unknown as SVGLineElement;
  const arrowDisc = document.getElementById('arrow-disc') as unknown as SVGLineElement;
  const lblCap    = document.getElementById('cap-lbl-cap')!;
  const lblDisc   = document.getElementById('cap-lbl-disc')!;
  const piRow     = document.getElementById('cap-pi-row')!;

  /* ── Helpers ──────────────────────────────────────────────── */
  function smoothstep(t: number) { const c = Math.max(0, Math.min(1, t)); return c * c * (3 - 2 * c); }
  function lerp(a: number, b: number, t: number) { return a + (b - a) * t; }
  function progress(time: number, start: number, end: number) { return smoothstep((time - start) / (end - start)); }

  /** Project a world-space point to viewport pixel coordinates. */
  function toScreen(pos: THREE.Vector3, cam: THREE.Camera, cvs: HTMLCanvasElement): [number, number] {
    const v = pos.clone().project(cam);
    return [
      ( v.x * 0.5 + 0.5) * cvs.clientWidth,
      (-v.y * 0.5 + 0.5) * cvs.clientHeight,
    ];
  }

  /* ── Three.js scene ───────────────────────────────────────── */
  const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

  const scene  = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(40, 2, 0.1, 100);
  camera.position.set(2.2, 1.6, 2.2);

  /* ── Camera orbit ──────────────────────────────────────────── */
  const CAM_RADIUS = 3.5;
  const CAM_HEIGHT = 1.6;
  const CAM_SPEED  = 0.15;   // radians per second

  /* ── Lighting ─────────────────────────────────────────────── */
  scene.add(new THREE.AmbientLight(0xffffff, 0.6));
  const dirLight = new THREE.DirectionalLight(0xffffff, 1.2);
  dirLight.position.set(3, 4, 2);
  scene.add(dirLight);

  /* ── Bottom hemisphere (the part that fades out) ──────────── */
  const bottomGeo = new THREE.SphereGeometry(R, 64, 32, 0, Math.PI * 2, THETA, Math.PI - THETA);
  const bottomMat = new THREE.MeshStandardMaterial({
    color: 0xcccccc, transparent: true, opacity: 0.15,
    side: THREE.DoubleSide, depthWrite: false,
  });
  const bottomMesh = new THREE.Mesh(bottomGeo, bottomMat);
  scene.add(bottomMesh);

  /* ── Wireframe overlay (bottom only — fades with bottom) ──── */
  const wireGeo = new THREE.SphereGeometry(R, 32, 16, 0, Math.PI * 2, THETA, Math.PI - THETA);
  const wireMat = new THREE.MeshBasicMaterial({
    color: 0xaaaaaa, wireframe: true, transparent: true, opacity: 0.08,
  });
  const wireMesh = new THREE.Mesh(wireGeo, wireMat);
  scene.add(wireMesh);

  /* ── Wireframe overlay on cap (stays visible) ──────────────── */
  const capWireGeo = new THREE.SphereGeometry(R * 1.001, 24, 8, 0, Math.PI * 2, 0, THETA);
  const capWireMat = new THREE.MeshBasicMaterial({
    color: 0xffffff, wireframe: true, transparent: true, opacity: 0.15,
  });
  scene.add(new THREE.Mesh(capWireGeo, capWireMat));

  /* ── Spherical cap (indigo) ───────────────────────────────── */
  const capGeo = new THREE.SphereGeometry(R, 64, 32, 0, Math.PI * 2, 0, THETA);
  const capMat = new THREE.MeshStandardMaterial({
    color: 0x6366f1, side: THREE.DoubleSide, transparent: true, opacity: 0.7,
  });
  const capMesh = new THREE.Mesh(capGeo, capMat);
  scene.add(capMesh);

  // Close the bottom of the cap so you can't see inside it
  const capBaseGeo = new THREE.CircleGeometry(R_CIRCLE, 64);
  const capBaseMesh = new THREE.Mesh(capBaseGeo, capMat);
  capBaseMesh.rotation.x = -Math.PI / 2;
  capBaseMesh.position.y = Y_DISC_ORIG;
  scene.add(capBaseMesh);

  /* ── Flat disc (red) ──────────────────────────────────────── */
  const discGeo = new THREE.CircleGeometry(R_CIRCLE, 64);
  const discMat = new THREE.MeshStandardMaterial({
    color: 0xd63030, side: THREE.DoubleSide, transparent: true, opacity: 0.55,
  });
  const discMesh = new THREE.Mesh(discGeo, discMat);
  discMesh.rotation.x = -Math.PI / 2;
  discMesh.position.y = Y_DISC_ORIG;
  scene.add(discMesh);

  /* ── Boundary circle outline ──────────────────────────────── */
  const ringPts: THREE.Vector3[] = [];
  for (let i = 0; i <= 96; i++) {
    const a = (i / 96) * Math.PI * 2;
    ringPts.push(new THREE.Vector3(R_CIRCLE * Math.cos(a), Y_DISC_ORIG, R_CIRCLE * Math.sin(a)));
  }
  const ringGeo = new THREE.BufferGeometry().setFromPoints(ringPts);
  const ringMat = new THREE.LineBasicMaterial({ color: 0x222222, transparent: true, opacity: 1 });
  const ringLine = new THREE.LineLoop(ringGeo, ringMat);
  scene.add(ringLine);

  /* ── 3D anchor points for label arrows ────────────────────── */
  const anchorCap  = new THREE.Vector3(0, R * 0.92, 0);        // near top of cap
  const anchorDisc = new THREE.Vector3(0, Y_DISC_ORIG, 0);     // disc centre (updated in loop)

  /* ── Animation state ──────────────────────────────────────── */
  const clock = new THREE.Clock();
  let animTime = 0;
  let isVisible = false;

  /* ── IntersectionObserver: only animate when on-screen ────── */
  const observer = new IntersectionObserver(
    ([entry]) => {
      if (entry.isIntersecting && !isVisible) {
        animTime = 0;  // restart on re-enter
        clock.getDelta(); // reset delta
      }
      isVisible = entry.isIntersecting;
    },
    { threshold: 0.15 },
  );
  observer.observe(canvas);

  /* ── Resize ───────────────────────────────────────────────── */
  function resize() {
    const w = canvas.clientWidth;
    const h = canvas.clientHeight;
    if (canvas.width !== w * devicePixelRatio || canvas.height !== h * devicePixelRatio) {
      renderer.setSize(w, h, false);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
    }
  }

  /* ── Update labels + arrows each frame ────────────────────── */
  function updateLabels(formulaOpacity: number) {
    if (formulaOpacity <= 0) {
      lblCap.style.opacity = '0';
      lblDisc.style.opacity = '0';
      arrowCap.style.opacity = '0';
      arrowDisc.style.opacity = '0';
      return;
    }

    const op = String(formulaOpacity);
    lblCap.style.opacity  = op;
    lblDisc.style.opacity = op;
    arrowCap.style.opacity  = op;
    arrowDisc.style.opacity = op;

    const w = canvas.clientWidth;
    const h = canvas.clientHeight;

    // Project 3D anchors → screen
    const [capX, capY]   = toScreen(anchorCap, camera, canvas);
    const [discX, discY] = toScreen(anchorDisc, camera, canvas);

    // Fixed label positions: offset to the right of the anchor
    const lblOffX = 60;
    const lblCapX  = Math.min(capX + lblOffX, w - 180);
    const lblCapY  = Math.max(capY - 20, 10);
    const lblDiscX = Math.min(discX + lblOffX, w - 180);
    const lblDiscY = Math.min(discY + 10, h - 30);

    lblCap.style.left  = lblCapX + 'px';
    lblCap.style.top   = lblCapY + 'px';
    lblDisc.style.left = lblDiscX + 'px';
    lblDisc.style.top  = lblDiscY + 'px';

    // Arrow lines (from label edge to 3D anchor)
    arrowCap.setAttribute('x1', String(lblCapX - 4));
    arrowCap.setAttribute('y1', String(lblCapY + 10));
    arrowCap.setAttribute('x2', String(capX));
    arrowCap.setAttribute('y2', String(capY));

    arrowDisc.setAttribute('x1', String(lblDiscX - 4));
    arrowDisc.setAttribute('y1', String(lblDiscY + 8));
    arrowDisc.setAttribute('x2', String(discX));
    arrowDisc.setAttribute('y2', String(discY));
  }

  /* ── Main animation loop ──────────────────────────────────── */
  function animate() {
    requestAnimationFrame(animate);
    if (!isVisible) return;

    const delta = clock.getDelta();
    animTime = (animTime + delta) % T_CYCLE;
    const t = animTime;

    resize();

    // ── Phase: fade out bottom hemisphere ──────────────────
    const bottomAlpha = t < T_FADE_START ? 1
      : t < T_FADE_END ? 1 - progress(t, T_FADE_START, T_FADE_END)
      : t >= T_FADEOUT_START ? progress(t, T_FADEOUT_START, T_FADEOUT_END)
      : 0;
    bottomMat.opacity = bottomAlpha * 0.15;
    wireMat.opacity   = bottomAlpha * 0.08;
    bottomMesh.visible = bottomAlpha > 0.01;
    wireMesh.visible   = bottomAlpha > 0.01;

    // ── Phase: separate disc downward ─────────────────────
    const sepP = t < T_SEPARATE_START ? 0
      : t < T_SEPARATE_END ? progress(t, T_SEPARATE_START, T_SEPARATE_END)
      : t >= T_FADEOUT_START ? 1 - progress(t, T_FADEOUT_START, T_FADEOUT_END)
      : 1;
    const discY = lerp(Y_DISC_ORIG, Y_DISC_ORIG - DISC_DROP, sepP);
    discMesh.position.y = discY;
    anchorDisc.y        = discY;

    // Move the ring outline with the disc once separated
    const ringPositions = ringLine.geometry.attributes.position;
    for (let i = 0; i < ringPositions.count; i++) {
      ringPositions.setY(i, discY);
    }
    ringPositions.needsUpdate = true;

    // ── Phase: formula labels + arrows ────────────────────
    const formulaOp = t < T_FORMULAS_START ? 0
      : t < T_FORMULAS_END ? progress(t, T_FORMULAS_START, T_FORMULAS_END)
      : t >= T_FADEOUT_START ? 1 - progress(t, T_FADEOUT_START, T_FADEOUT_END)
      : 1;

    updateLabels(formulaOp);

    // ── Phase: π values row ───────────────────────────────
    const piOp = t < T_PI_START ? 0
      : t < T_PI_END ? progress(t, T_PI_START, T_PI_END)
      : t >= T_FADEOUT_START ? 1 - progress(t, T_FADEOUT_START, T_FADEOUT_END)
      : 1;
    piRow.style.opacity = String(piOp);

    // ── Camera orbit ─────────────────────────────────────
    const angle = animTime * CAM_SPEED;
    camera.position.set(
      CAM_RADIUS * Math.sin(angle),
      CAM_HEIGHT,
      CAM_RADIUS * Math.cos(angle),
    );
    camera.lookAt(0, 0.2, 0);

    // ── Render ────────────────────────────────────────────
    renderer.render(scene, camera);
  }
  animate();
</script>
