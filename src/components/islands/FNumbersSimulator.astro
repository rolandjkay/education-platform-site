const t = { ...labels.en, ...(labels[locale] ?? {}) };
---

<div class="f-numbers-container" id="f-numbers-container" data-translations={JSON.stringify(t)}>
  <canvas class="webgl" aria-label="Interactive f-numbers and depth of field 3D simulator"></canvas>

  <div class="mobile-placeholder" id="mobile-placeholder">
    <div class="placeholder-content">
      <p class="placeholder-title">{t.placeholderTitle}</p>
      <p class="placeholder-desc">{t.placeholderDesc}</p>
      <button class="launch-btn" id="launch-btn">&#9654; {t.launchBtn}</button>
    </div>
  </div>

  <div class="rotate-hint" id="rotate-hint">
    <p>&#8635; {t.rotateHint}</p>
  </div>
</div>

<style>
  .f-numbers-container {
    position: relative;
    width: 100%;
    height: 70vh;
    overflow: hidden;
    background: #111;
  }

  canvas.webgl {
    display: block;
    width: 100%;
    height: 100%;
    outline: none;
  }

  /* --- Mobile placeholder (hidden on desktop) --- */
  .mobile-placeholder {
    display: none;
  }

  @media (pointer: coarse) {
    .mobile-placeholder {
      display: flex;
      position: absolute;
      inset: 0;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #0d0d0d 0%, #1a1a2e 100%);
      z-index: 20;
    }
  }

  /* In landscape on touch devices, use the full viewport height so iOS
     (which can't go fullscreen) still gets a usable canvas size. */
  @media (pointer: coarse) and (orientation: landscape) {
    .f-numbers-container {
      height: 100vh;
    }
  }


  .placeholder-content {
    text-align: center;
    padding: 24px;
    font-family: "Space Grotesk", Helvetica, sans-serif;
    color: #fff;
    max-width: 320px;
  }

  .placeholder-title {
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 10px;
  }

  .placeholder-desc {
    font-size: 14px;
    color: rgba(255,255,255,0.65);
    margin: 0 0 28px;
    line-height: 1.5;
  }

  .launch-btn {
    font-family: "Space Grotesk", Helvetica, sans-serif;
    font-size: 15px;
    font-weight: 600;
    color: #fff;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.35);
    border-radius: 8px;
    padding: 14px 32px;
    cursor: pointer;
    transition: background 0.2s;
    min-height: 44px;
  }

  .launch-btn:active {
    background: rgba(255,255,255,0.25);
  }

  /* --- Rotate hint (shown in fullscreen portrait on touch devices) --- */
  .rotate-hint {
    display: none;
  }
</style>

<script>
  import Experience from '../../scripts/f-numbers/Experience/Experience.js';

  const isTouchDevice = window.matchMedia('(pointer: coarse)').matches;
  const canvas        = document.querySelector('canvas.webgl') as HTMLCanvasElement;
  const container     = document.getElementById('f-numbers-container')!;
  const placeholder   = document.getElementById('mobile-placeholder')!;
  const launchBtn     = document.getElementById('launch-btn')!;
  const rotateHint    = document.getElementById('rotate-hint')!;

  let experienceStarted = false;
  // True once the user has launched the app and the canvas is showing.
  // Used to decide whether to show the rotate hint (as opposed to the placeholder).
  let appActive = false;

  function startExperience() {
    if (experienceStarted) return;
    experienceStarted = true;
    new Experience(canvas);
  }

  function isPortrait() {
    return window.matchMedia('(orientation: portrait)').matches;
  }

  function updateRotateHint() {
    // Show the hint whenever the app is running and the device is in portrait.
    // This covers iOS (no fullscreen API) as well as Android.
    if (appActive && isPortrait()) {
      rotateHint.style.cssText =
        'display:flex;position:absolute;inset:0;align-items:center;justify-content:center;' +
        'background:rgba(0,0,0,0.75);color:#fff;font-family:"Space Grotesk",sans-serif;' +
        'font-size:16px;z-index:20;';
    } else {
      rotateHint.style.display = 'none';
    }
  }

  if (!isTouchDevice) {
    // Desktop: start immediately, no placeholder needed
    startExperience();
  } else {
    // Mobile: hide canvas until the user launches the app
    canvas.style.display = 'none';

    launchBtn.addEventListener('click', async () => {
      // Hide placeholder and reveal canvas
      placeholder.style.display = 'none';
      canvas.style.display = 'block';
      appActive = true;

      // Request fullscreen on the container (works on Android; iOS silently ignores it)
      try {
        await container.requestFullscreen();
      } catch (_) {}

      // Try to lock orientation to landscape (works on Android Chrome; iOS ignores it)
      try {
        await (screen.orientation as any).lock('landscape');
      } catch (_) {}

      updateRotateHint();
      startExperience();
    });

    // On Android: exiting fullscreen brings back the placeholder
    document.addEventListener('fullscreenchange', () => {
      if (!document.fullscreenElement) {
        // Stop fly-by if it was running mid-tour
        (window as any).experience?.world?.flyByTour?.stopFlyBy();

        appActive = false;
        placeholder.style.display = 'flex';
        canvas.style.display = 'none';
        rotateHint.style.display = 'none';

      }
    });

    window.addEventListener('orientationchange', updateRotateHint);
    window.addEventListener('resize', updateRotateHint);
  }
</script>
