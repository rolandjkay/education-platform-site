---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/Card.astro';
import CardGrid from '../../components/CardGrid.astro';

const articles = (await getCollection('articles')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title="Articles"
  description="Science and filmmaking articles from Amersham Film School — written for curious young learners."
>
  <div class="container">
    <header class="page-header">
      <p class="page-header__eyebrow">Online Learning</p>
      <h1 class="page-header__title">Articles</h1>
      <p class="page-header__description">
        In-depth articles on physics, optics, and filmmaking — with interactive
        tools to bring the concepts to life.
      </p>
    </header>

    {articles.length > 0 ? (
      <CardGrid>
        {articles.map(article => (
          <Card
            title={article.data.title}
            description={article.data.description}
            href={`/articles/${article.id.replace(/\.mdx?$/, '')}`}
            image={article.data.heroImage}
            tag={article.data.tags?.[0]}
            date={article.data.pubDate}
          />
        ))}
      </CardGrid>
    ) : (
      <p class="empty-state">No articles yet — check back soon.</p>
    )}
  </div>
</BaseLayout>

<style>
  .empty-state {
    text-align: center;
    color: var(--color-text-muted);
    padding: 4rem 0;
    font-family: var(--font-sans);
  }
</style>
