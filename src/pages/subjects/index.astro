---
import BaseLayout from '../../layouts/BaseLayout.astro';

const subjects = [
  {
    slug: 'maths',
    label: 'Maths',
    description: 'From the elegance of Euler\'s number to the logic of proof — maths as it was meant to be understood.',
    icon: '∑',
  },
  {
    slug: 'science',
    label: 'Science',
    description: 'Physics, optics, and the science behind the world around you — explored with interactive tools.',
    icon: '⚛',
  },
  {
    slug: 'finance',
    label: 'Finance',
    description: 'How money actually works: compound interest, valuation, risk, and the maths behind smart decisions.',
    icon: '£',
  },
  {
    slug: 'filmmaking',
    label: 'Filmmaking',
    description: 'Cameras, lenses, light, and storytelling — the craft and science of making films.',
    icon: '▶',
  },
];
---

<BaseLayout
  title="Subjects"
  description="Browse articles by subject — maths, science, finance, and filmmaking."
>
  <div class="container">
    <header class="page-header">
      <p class="page-header__eyebrow">Online Learning</p>
      <h1 class="page-header__title">Subjects</h1>
      <p class="page-header__description">
        Pick a subject and start exploring — each one is packed with articles,
        interactive tools, and ideas to get you thinking.
      </p>
    </header>

    <ul class="subjects-grid" role="list">
      {subjects.map(subject => (
        <li>
          <a href={`/subjects/${subject.slug}`} class="subject-card">
            <span class="subject-card__icon" aria-hidden="true">{subject.icon}</span>
            <h2 class="subject-card__title">{subject.label}</h2>
            <p class="subject-card__description">{subject.description}</p>
            <span class="subject-card__cta">Browse {subject.label} →</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>

<style>
  .subjects-grid {
    list-style: none;
    padding: 0;
    margin: 0 0 5rem;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(280px, 100%), 1fr));
    gap: 1.5rem;
  }

  .subject-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 2rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
  }

  .subject-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-hover);
    border-color: var(--color-primary);
  }

  .subject-card__icon {
    font-size: 2rem;
    line-height: 1;
    color: var(--color-primary);
  }

  .subject-card__title {
    font-family: var(--font-sans);
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
  }

  .subject-card__description {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    flex: 1;
    margin: 0;
  }

  .subject-card__cta {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-top: 0.5rem;
  }
</style>
