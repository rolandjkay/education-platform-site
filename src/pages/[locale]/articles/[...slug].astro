---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { useTranslations, localePath, locales, defaultLocale, getContentLocale, getContentSlug, localeToBcp47, type Locale } from '../../../i18n/utils';

export async function getStaticPaths() {
  const allArticles = await getCollection('articles');
  const nonDefaultLocales = locales.filter(l => l !== defaultLocale);

  return nonDefaultLocales.flatMap(locale =>
    allArticles
      .filter(a => !a.data.draft && getContentLocale(a.id) === locale)
      .map(entry => ({
        params: { locale, slug: getContentSlug(entry.id) },
        props: { entry, locale },
      }))
  );
}

const { entry, locale } = Astro.props as { entry: any; locale: Locale };
const t = useTranslations(locale);
const { Content } = await render(entry);

const slug = getContentSlug(entry.id);
const formattedDate = entry.data.pubDate.toLocaleDateString(localeToBcp47[locale], {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  image={entry.data.heroImage?.src}
  locale={locale}
  canonicalPath={`/articles/${slug}`}
>
  <article>
    <div class="container">
      <header class="article-header">
        <div class="article-header__meta">
          <a href={localePath('/', locale)} class="back-link">{t('nav.back')}</a>
          {entry.data.tags && entry.data.tags.length > 0 && (
            <ul class="tag-list" aria-label="Tags">
              {entry.data.tags.map((tag: string) => <li><span class="tag">{tag}</span></li>)}
            </ul>
          )}
        </div>
        <h1>{entry.data.title}</h1>
        <time datetime={entry.data.pubDate.toISOString()} class="article-date">{formattedDate}</time>
      </header>

      {entry.data.heroImage && (
        <Image
          src={entry.data.heroImage}
          alt=""
          class="article-hero-image"
          loading="eager"
        />
      )}
    </div>

    <div class="container article-body prose">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .back-link {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    transition: color var(--transition);
  }
  .back-link:hover { color: var(--color-primary); }
  .article-date {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    display: block;
    margin-top: 0.75rem;
  }
  .article-hero-image {
    width: 100%;
    max-height: 480px;
    object-fit: cover;
    border-radius: var(--radius-lg);
    margin-bottom: 3rem;
  }
</style>
