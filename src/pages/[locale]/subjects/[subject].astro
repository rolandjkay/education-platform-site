---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Card from '../../../components/Card.astro';
import CardGrid from '../../../components/CardGrid.astro';
import { useTranslations, localePath, locales, defaultLocale, getContentLocale, getContentSlug, type Locale } from '../../../i18n/utils';

type Subject = 'maths' | 'science' | 'finance' | 'filmmaking';

export async function getStaticPaths() {
  const subjects: Subject[] = ['maths', 'science', 'finance', 'filmmaking'];
  return locales
    .filter(l => l !== defaultLocale)
    .flatMap(locale => subjects.map(subject => ({ params: { locale, subject } })));
}

const { locale, subject } = Astro.params as { locale: Locale; subject: Subject };
const t = useTranslations(locale);

const articles = (await getCollection('articles'))
  .filter(a => !a.data.draft && getContentLocale(a.id) === locale && a.data.subjects.includes(subject))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const allApps = await getCollection('apps');
const apps = allApps
  .filter(a => getContentLocale(a.id) === 'en' && a.data.subjects?.includes(subject))
  .map(enApp => {
    const slug = getContentSlug(enApp.id);
    return allApps.find(a => getContentLocale(a.id) === locale && getContentSlug(a.id) === slug) ?? enApp;
  });

const projects = (await getCollection('projects'))
  .filter(p => getContentLocale(p.id) === locale && p.data.subjects?.includes(subject))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title={t(`subjects.${subject}.label` as any)}
  description={t(`subjects.${subject}.description` as any)}
  locale={locale}
  canonicalPath={`/subjects/${subject}`}
>
  <div class="container" style={`--subject-color: var(--color-${subject}); --subject-faint: var(--color-${subject}-faint)`}>
    <header class="page-header">
      <p class="page-header__eyebrow"><a href={localePath('/', locale)}>{t('subject.breadcrumb')}</a></p>
      <h1 class="page-header__title">{t(`subjects.${subject}.label` as any)}</h1>
      <p class="page-header__description">{t(`subjects.${subject}.description` as any)}</p>
    </header>

    {articles.length > 0 && (
      <section class="subject-section">
        <h2 class="subject-section__heading">{t('subject.articles')}</h2>
        <CardGrid>
          {articles.map((article, i) => (
            <Card
              title={article.data.title}
              description={article.data.description}
              href={localePath(`/articles/${getContentSlug(article.id)}`, locale)}
              image={article.data.heroImage}
              tag={article.data.tags?.[0]}
              date={article.data.pubDate}
              accentColor={`var(--color-${subject})`}
              locale={locale}
              loading={i < 3 ? 'eager' : 'lazy'}
            />
          ))}
        </CardGrid>
      </section>
    )}

    {apps.length > 0 && (
      <section class="subject-section">
        <h2 class="subject-section__heading">{t('subject.apps')}</h2>
        <CardGrid>
          {apps.map((app, i) => (
            <Card
              title={app.data.title}
              description={app.data.description}
              href={localePath(`/apps/${getContentSlug(app.id)}`, locale)}
              accentColor={`var(--color-${subject})`}
              locale={locale}
              loading={i < 3 ? 'eager' : 'lazy'}
            />
          ))}
        </CardGrid>
      </section>
    )}

    {projects.length > 0 && (
      <section class="subject-section">
        <h2 class="subject-section__heading">{t('subject.projects')}</h2>
        <CardGrid>
          {projects.map((project, i) => (
            <Card
              title={project.data.title}
              description={project.data.description}
              href={`/projects/${project.id.replace(/\.mdx?$/, '')}`}
              image={project.data.heroImage}
              accentColor={`var(--color-${subject})`}
              locale={locale}
              loading={i < 3 ? 'eager' : 'lazy'}
            />
          ))}
        </CardGrid>
      </section>
    )}

    {articles.length === 0 && apps.length === 0 && projects.length === 0 && (
      <p class="empty-state">{t('subject.empty')}</p>
    )}
  </div>
</BaseLayout>

<style>
  .page-header__eyebrow a {
    color: var(--subject-color, var(--color-primary));
    text-decoration: none;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .page-header__eyebrow a:hover { text-decoration: underline; }
  .subject-section { margin-bottom: 4rem; }
  .subject-section__heading {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 1.5rem;
    padding-bottom: 0.625rem;
    border-bottom: 2px solid var(--subject-color, var(--color-border));
  }
  .empty-state {
    text-align: center;
    color: var(--color-text-muted);
    padding: 4rem 0;
    font-family: var(--font-sans);
  }
</style>
