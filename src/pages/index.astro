---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/Card.astro';
import CardGrid from '../components/CardGrid.astro';
import { getContentLocale } from '../i18n/utils';

const latest = (await getCollection('articles', a => !a.data.draft && getContentLocale(a.id) === 'en'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout
  title="Online Learning"
  description="Maths, science, finance, and filmmaking — explored through articles, interactive apps, and hands-on projects."
>
  <section class="hub-hero">
    <div class="container">
      <div class="hub-hero__accent" aria-hidden="true"></div>
      <p class="hub-hero__eyebrow">Amersham Film School</p>
      <h1 class="hub-hero__title">Online Learning</h1>
      <p class="hub-hero__subtitle">
        Maths, science, finance, and filmmaking — explained clearly,
        explored interactively, and always worth your time.
      </p>
    </div>
  </section>

  <div class="container">
    <nav class="hub-grid" aria-label="Subjects">
      <a href="/subjects/maths" class="hub-card hub-card--maths">
        <div class="hub-card__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="3" x2="12" y2="21"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </div>
        <div class="hub-card__title">Maths</div>
        <p class="hub-card__description">
          From Euler's number to the logic of proof — maths as it was meant to be understood.
        </p>
        <span class="hub-card__cta">Browse Maths →</span>
      </a>

      <a href="/subjects/science" class="hub-card hub-card--science">
        <div class="hub-card__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="2"/>
            <ellipse cx="12" cy="12" rx="10" ry="2.5"/>
            <ellipse cx="12" cy="12" rx="10" ry="2.5" transform="rotate(60 12 12)"/>
            <ellipse cx="12" cy="12" rx="10" ry="2.5" transform="rotate(120 12 12)"/>
          </svg>
        </div>
        <div class="hub-card__title">Science</div>
        <p class="hub-card__description">
          Physics, optics, and the science behind the world around you — with interactive tools.
        </p>
        <span class="hub-card__cta">Browse Science →</span>
      </a>

      <a href="/subjects/finance" class="hub-card hub-card--finance">
        <div class="hub-card__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="2" x2="12" y2="22"/>
            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
          </svg>
        </div>
        <div class="hub-card__title">Finance</div>
        <p class="hub-card__description">
          How money actually works: compound interest, valuation, and the maths behind smart decisions.
        </p>
        <span class="hub-card__cta">Browse Finance →</span>
      </a>

      <a href="/subjects/filmmaking" class="hub-card hub-card--filmmaking">
        <div class="hub-card__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.2 6 3 11l-.9-2.4c-.3-1.1.3-2.2 1.3-2.5l13.5-4a2 2 0 0 1 2.5 1.3Z"/>
            <path d="m6.2 5.3 3.1 3.9"/>
            <path d="m12.4 3.4 3.1 4"/>
            <path d="M3 11h18v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2Z"/>
          </svg>
        </div>
        <div class="hub-card__title">Filmmaking</div>
        <p class="hub-card__description">
          Cameras, lenses, light, and storytelling — the craft and science of making films.
        </p>
        <span class="hub-card__cta">Browse Filmmaking →</span>
      </a>
    </nav>

    {latest.length > 0 && (
      <section class="latest-section">
        <h2 class="latest-section__heading">Latest Articles</h2>
        <CardGrid>
          {latest.map((article, i) => (
            <Card
              title={article.data.title}
              description={article.data.description}
              href={`/articles/${article.id.replace(/\.mdx?$/, '')}`}
              image={article.data.heroImage}
              date={article.data.pubDate}
              accentColor={`var(--color-${article.data.subjects[0]})`}
              loading={i < 2 ? 'eager' : 'lazy'}
            />
          ))}
        </CardGrid>
      </section>
    )}
  </div>
</BaseLayout>

<style>
  .hub-hero__accent {
    width: 3rem;
    height: 3px;
    background: var(--color-primary);
    margin-bottom: 1.5rem;
    border-radius: 2px;
  }

  .hub-hero__eyebrow {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 0.75rem;
  }

  .latest-section {
    padding-bottom: 5rem;
  }

  .latest-section__heading {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 1.5rem;
    padding-bottom: 0.625rem;
    border-bottom: 1px solid var(--color-border);
  }
</style>
