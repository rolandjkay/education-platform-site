---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Online Learning"
  description="Interactive science articles, filmmaking project guides, and educational apps from Amersham Film School."
>
  <section class="hub-hero">
    <div class="container">
      <div class="hub-hero__accent" aria-hidden="true"></div>
      <p class="hub-hero__eyebrow">Amersham Film School</p>
      <h1 class="hub-hero__title">Online Learning</h1>
      <p class="hub-hero__subtitle">
        Explore science through interactive apps, learn filmmaking with hands-on
        project guides, and dive into educational articles.
      </p>
      <nav class="hub-hero__nav" aria-label="Content sections">
        <a href="/articles" class="btn btn--primary">Articles</a>
        <a href="/projects" class="btn btn--outline">Projects</a>
        <a href="/apps" class="btn btn--outline">Interactive Apps</a>
      </nav>
    </div>
  </section>

  <div class="container">
    <nav class="hub-grid" aria-label="Content section cards">
      <a href="/articles" class="hub-card">
        <div class="hub-card__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
          </svg>
        </div>
        <div class="hub-card__title">Articles</div>
        <p class="hub-card__description">
          In-depth science and filmmaking articles, from GCSE physics to
          camera optics, written for curious young learners.
        </p>
        <span class="hub-card__cta">Browse articles →</span>
      </a>

      <a href="/projects" class="hub-card">
        <div class="hub-card__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.2 6 3 11l-.9-2.4c-.3-1.1.3-2.2 1.3-2.5l13.5-4a2 2 0 0 1 2.5 1.3Z"/>
            <path d="m6.2 5.3 3.1 3.9"/>
            <path d="m12.4 3.4 3.1 4"/>
            <path d="M3 11h18v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2Z"/>
          </svg>
        </div>
        <div class="hub-card__title">Projects</div>
        <p class="hub-card__description">
          Step-by-step filmmaking and creative projects you can do at home —
          from music videos to animation and beyond.
        </p>
        <span class="hub-card__cta">Browse projects →</span>
      </a>

      <a href="/apps" class="hub-card">
        <div class="hub-card__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <rect x="4.25" y="3.5" width="3.5" height="17" fill="none"/>
            <polygon points="11,3 24,12 11,21" fill="none" stroke="currentColor"/>
          </svg>
        </div>
        <div class="hub-card__title">Interactive Apps</div>
        <p class="hub-card__description">
          Hands-on physics simulators — drag objects, adjust apertures, and
          watch the science happen in real time.
        </p>
        <span class="hub-card__cta">Open apps →</span>
      </a>
    </nav>
  </div>
</BaseLayout>

<style>
  .hub-hero__accent {
    width: 3rem;
    height: 3px;
    background: var(--color-primary);
    margin-bottom: 1.5rem;
    border-radius: 2px;
  }

  .hub-hero__eyebrow {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 0.75rem;
  }
</style>
