---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const apps = await getCollection('apps');

const appLinks: Record<string, string> = {
  'f-numbers-simulator': '/apps/f-numbers',
  'convex-lens-simulator': '/apps/convex-lens-simulator',
  'pinhole-simulator': '/apps/pinhole-simulator',
};

const appTypeLabel: Record<string, string> = {
  threejs: '3D / WebGL',
  canvas: 'Canvas 2D',
  other: 'Interactive',
};
---

<BaseLayout
  title="Interactive Apps"
  description="Hands-on physics and optics simulators from Amersham Film School."
>
  <div class="container">
    <header class="page-header">
      <p class="page-header__eyebrow">Online Learning</p>
      <h1 class="page-header__title">Interactive Apps</h1>
      <p class="page-header__description">
        Physics simulators you can interact with directly in your browser —
        no install needed.
      </p>
    </header>

    <ul class="apps-list" role="list">
      {apps.map(app => {
        const slug = app.id.replace(/\.mdx?$/, '');
        const href = appLinks[slug] ?? `/apps/${slug}`;
        return (
          <li class="app-item">
            <a href={href} class="app-item__link">
              <div class="app-item__icon" aria-hidden="true">
                {app.data.appType === 'threejs' ? '🔮' : '🔬'}
              </div>
              <div class="app-item__body">
                <span class="app-item__type">{appTypeLabel[app.data.appType] ?? app.data.appType}</span>
                <h2 class="app-item__title">{app.data.title}</h2>
                <p class="app-item__description">{app.data.description}</p>
              </div>
              <span class="app-item__cta" aria-hidden="true">Open →</span>
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</BaseLayout>

<style>
  .apps-list {
    list-style: none;
    padding: 0;
    margin: 0 0 4rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .app-item__link {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
  }

  .app-item__link:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-hover);
    border-color: var(--color-primary);
  }

  .app-item__icon {
    font-size: 2.5rem;
    flex-shrink: 0;
    width: 64px;
    height: 64px;
    background: var(--color-primary-light);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .app-item__body {
    flex: 1;
    min-width: 0;
  }

  .app-item__type {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-primary);
    display: block;
    margin-bottom: 0.25rem;
  }

  .app-item__title {
    font-size: 1.125rem;
    margin-bottom: 0.375rem;
  }

  .app-item__description {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.5;
  }

  .app-item__cta {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
    flex-shrink: 0;
    transition: transform var(--transition);
  }

  .app-item__link:hover .app-item__cta {
    transform: translateX(4px);
  }

  @media (max-width: 480px) {
    .app-item__link {
      flex-wrap: wrap;
      gap: 1rem;
    }

    .app-item__cta {
      display: none;
    }
  }
</style>
