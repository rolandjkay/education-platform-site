---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const apps = await getCollection('apps');

const appLinks: Record<string, string> = {
  'f-numbers-simulator': '/apps/f-numbers',
  'convex-lens-simulator': '/apps/convex-lens-simulator',
  'pinhole-simulator': '/apps/pinhole-simulator',
};

const appTypeLabel: Record<string, string> = {
  threejs: '3D / WebGL',
  canvas: 'Canvas 2D',
  other: 'Interactive',
};
---

<BaseLayout
  title="Interactive Apps"
  description="Hands-on physics and optics simulators from Amersham Film School."
>
  <div class="container">
    <header class="page-header">
      <p class="page-header__eyebrow">Online Learning</p>
      <h1 class="page-header__title">Interactive Apps</h1>
      <p class="page-header__description">
        Physics simulators you can interact with directly in your browser —
        no install needed.
      </p>
    </header>

    <ul class="apps-list" role="list">
      {apps.map(app => {
        const slug = app.id.replace(/\.mdx?$/, '');
        const href = appLinks[slug] ?? `/apps/${slug}`;
        return (
          <li class="app-item">
            <a href={href} class="app-item__link">
              <div class="app-item__icon" aria-hidden="true">
                {slug === 'pinhole-simulator' ? (
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="8" width="13" height="12"/>
                    <polygon points="2,8 15,8 21,3 8,3"/>
                    <polygon points="15,8 21,3 21,15 15,20"/>
                    <circle cx="8.5" cy="14" r="2" fill="currentColor" stroke="none"/>
                  </svg>
                ) : slug === 'convex-lens-simulator' ? (
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12,3 A12,12 0 0,1 12,21 A12,12 0 0,1 12,3 Z"/>
                    <g stroke-opacity="0.5">
                      <line x1="1" y1="12" x2="8" y2="12"/>
                      <line x1="8" y1="12" x2="16" y2="12" stroke-opacity="0.15"/>
                      <line x1="16" y1="12" x2="22" y2="12"/>
                      <line x1="1" y1="7" x2="9" y2="7"/>
                      <line x1="9" y1="7" x2="15" y2="7" stroke-opacity="0.15"/>
                      <line x1="15" y1="7" x2="22" y2="12"/>
                      <line x1="1" y1="17" x2="9" y2="17"/>
                      <line x1="9" y1="17" x2="15" y2="17" stroke-opacity="0.15"/>
                      <line x1="15" y1="17" x2="22" y2="12"/>
                    </g>
                  </svg>
                ) : (
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="14.31" y1="8" x2="20.05" y2="17.94"/>
                    <line x1="9.69" y1="8" x2="21.17" y2="8"/>
                    <line x1="7.38" y1="12" x2="13.12" y2="2.06"/>
                    <line x1="9.69" y1="16" x2="3.95" y2="6.06"/>
                    <line x1="14.31" y1="16" x2="2.83" y2="16"/>
                    <line x1="16.62" y1="12" x2="10.88" y2="21.94"/>
                  </svg>
                )}
              </div>
              <div class="app-item__body">
                <span class="app-item__type">{appTypeLabel[app.data.appType] ?? app.data.appType}</span>
                <h2 class="app-item__title">{app.data.title}</h2>
                <p class="app-item__description">{app.data.description}</p>
              </div>
              <span class="app-item__cta" aria-hidden="true">Open →</span>
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</BaseLayout>

<style>
  .apps-list {
    list-style: none;
    padding: 0;
    margin: 0 0 4rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .app-item__link {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
  }

  .app-item__link:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-hover);
    border-color: var(--color-primary);
  }

  .app-item__icon {
    flex-shrink: 0;
    width: 64px;
    height: 64px;
    background: var(--color-primary-light);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary-dark);
  }

  .app-item__icon svg {
    width: 36px;
    height: 36px;
  }

  .app-item__body {
    flex: 1;
    min-width: 0;
  }

  .app-item__type {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-primary);
    display: block;
    margin-bottom: 0.25rem;
  }

  .app-item__title {
    font-size: 1.125rem;
    margin-bottom: 0.375rem;
  }

  .app-item__description {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.5;
  }

  .app-item__cta {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
    flex-shrink: 0;
    transition: transform var(--transition);
  }

  .app-item__link:hover .app-item__cta {
    transform: translateX(4px);
  }

  @media (max-width: 480px) {
    .app-item__link {
      flex-wrap: wrap;
      gap: 1rem;
    }

    .app-item__cta {
      display: none;
    }
  }
</style>
