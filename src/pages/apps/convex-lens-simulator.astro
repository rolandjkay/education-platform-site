---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ConvexLensEmbed from '../../components/diagrams/ConvexLensEmbed.astro';

const apps = await getCollection('apps');
const entry = apps.find(a => a.id.replace(/\.mdx?$/, '') === 'convex-lens-simulator');

if (!entry) throw new Error('convex-lens-simulator content entry not found');

const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <div class="container">
    <header class="article-header">
      <div class="article-header__meta">
        <a href="/" class="back-link">← Home</a>
        <span class="tag">Canvas 2D</span>
      </div>
      <h1>{entry.data.title}</h1>
    </header>
  </div>

  <div class="app-container container">
    <ConvexLensEmbed />
  </div>

  <div class="container article-body prose">
    <Content />
  </div>
</BaseLayout>

<style>
  .app-container {
    margin-bottom: 3rem;
  }

  .back-link {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition);
  }

  .back-link:hover {
    color: var(--color-primary);
  }
</style>
